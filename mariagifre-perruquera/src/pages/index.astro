---
import Layout from '../layouts/Layout.astro'

const horaris = [
  { label: 'Dimarts — Divendres', hores: '9 — 19h' },
  { label: 'Dissabte',            hores: '9 — 14h' },
  { label: 'Diumenge & Dilluns',  hores: 'Tancat' },
]
---

<Layout
  title="Maria Gifra & Paula Perruquers — Porqueres"
  description="Perruqueria a Porqueres des de 1967. Especialistes en color, balayage, babylights, tall i tractaments. Demana cita al 972 572 601."
>

  <!-- Colour tape -->
  <div class="tape h-1 w-full"></div>

  <!-- ===== NAV ===== -->
  <header class="nav-blur sticky top-0 z-40 border-b hairline">
    <div class="max-w-[1360px] mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between">
      <a href="#" class="flex items-center gap-3">
        <span class="display text-[22px] md:text-[26px] leading-none">
          Maria Gifra <span class="italic text-taupe">&amp;</span> Paula
        </span>
        <span class="hidden md:inline-block mono-label text-muted border-l hairline pl-3 ml-1">Perruqueres · Porqueres</span>
      </a>

      <nav class="hidden md:flex items-center gap-8 mono-label" style="color:rgba(28,26,24,0.8)">
        <a href="#serveis"  class="hover:text-taupe transition">Serveis</a>
        <a href="#color"    class="hover:text-taupe transition">Color</a>
        <a href="#nupcial"  class="hover:text-taupe transition">Nupcial</a>
        <a href="#salo"     class="hover:text-taupe transition">El saló</a>
        <a href="#contacte" class="hover:text-taupe transition">Contacte</a>
      </nav>

      <a href="tel:+34972572601"
         class="hidden md:inline-flex items-center gap-2 bg-ink text-linen px-4 py-2.5 mono-label hover:bg-taupe transition">
        <span class="w-1.5 h-1.5 rounded-full bg-sand"></span>
        972 572 601
      </a>

      <button class="md:hidden mono-label border hairline px-3 py-2 text-ink">Menú</button>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section class="relative bg-wash">
    <div class="max-w-[1360px] mx-auto px-6 md:px-10 pt-14 md:pt-24 pb-16 md:pb-28 grid md:grid-cols-12 gap-8 md:gap-12 items-end">

      <!-- Left: headline -->
      <div class="md:col-span-7 rise">
        <div class="mono-label text-taupe mb-8 flex items-center gap-3">
          <span class="w-8 h-px bg-taupe"></span>
          Porqueres · Girona · Des de 1967
        </div>

        <h1 class="display text-ink leading-[1.02] text-[56px] sm:text-[76px] md:text-[104px] lg:text-[124px]">
          L'art del <span class="italic text-rose">tall</span>
          <br/>
          i el <span class="italic text-terracotta">color</span>.
        </h1>

        <p class="mt-12 md:mt-16 max-w-[46ch] text-[17px] md:text-[19px] leading-[1.55] font-light" style="color:rgba(28,26,24,0.75)">
          Perruqueria familiar a Porqueres des de <span class="highlight-underline">1967</span>. Tres generacions dedicades
          al color, el tall i el benestar de cada persona que seu a la nostra cadira.
        </p>

        <!-- Colour swatches -->
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="swatch"><span class="dot" style="background:#3A2418"></span><span class="lbl">Xocolata</span></span>
          <span class="swatch"><span class="dot" style="background:#6B3A3A"></span><span class="lbl">Caoba</span></span>
          <span class="swatch"><span class="dot" style="background:#B46A4E"></span><span class="lbl">Terracota</span></span>
          <span class="swatch"><span class="dot" style="background:#D9A85C"></span><span class="lbl">Mel</span></span>
          <span class="swatch"><span class="dot" style="background:#E8C9BA"></span><span class="lbl">Rubor</span></span>
          <span class="swatch"><span class="dot" style="background:#EFE0C8"></span><span class="lbl">Sorra</span></span>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 sm:items-center">
          <a href="tel:+34972572601"
             class="inline-flex items-center justify-between gap-6 bg-ink text-linen px-6 py-4 hover:bg-taupe transition group">
            <span class="mono-label">Demanar cita</span>
            <span class="display text-[20px] italic">972 572 601</span>
            <span class="inline-block w-6 h-px bg-linen group-hover:w-10 transition-all"></span>
          </a>
          <a href="#serveis"
             class="inline-flex items-center gap-3 px-6 py-4 border hairline hover:border-taupe hover:text-taupe transition mono-label text-ink">
            Veure serveis
            <span aria-hidden>→</span>
          </a>
        </div>

        <!-- Micro stats -->
        <div class="mt-16 md:mt-20 grid grid-cols-3 gap-6 md:gap-10 max-w-xl border-t hairline pt-8">
          <div>
            <div class="display text-[34px] md:text-[42px] leading-none text-terracotta">57</div>
            <div class="mono-label text-muted mt-2">Anys<br/>d'ofici</div>
          </div>
          <div>
            <div class="display text-[34px] md:text-[42px] leading-none text-honey">3</div>
            <div class="mono-label text-muted mt-2">Generacions<br/>a casa</div>
          </div>
          <div>
            <div class="display text-[34px] md:text-[42px] leading-none text-rose italic">∞</div>
            <div class="mono-label text-muted mt-2">Matisos<br/>per cabell</div>
          </div>
        </div>
      </div>

      <!-- Right: portrait photo -->
      <div class="md:col-span-5 rise-2 relative">
        <!-- Colour strip side rail -->
        <div class="absolute -left-3 top-0 w-2 h-2/3 hidden md:flex flex-col">
          <div class="flex-1" style="background:#3A2418"></div>
          <div class="flex-1" style="background:#6B3A3A"></div>
          <div class="flex-1" style="background:#B46A4E"></div>
          <div class="flex-1" style="background:#D9A85C"></div>
          <div class="flex-1" style="background:#E8C9BA"></div>
        </div>

        <div class="aspect-[3/4] w-full overflow-hidden relative">
          <img
            src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=80"
            alt="Resultat de balayage a Maria Gifra &amp; Paula Perruquers, Porqueres"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>

        <!-- Floating caption card -->
        <div class="hidden md:block absolute -left-10 bottom-8 bg-linen border hairline px-5 py-4 shadow-[0_20px_40px_-25px_rgba(28,26,24,0.35)]">
          <div class="mono-label text-terracotta flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-honey"></span>
            Tècnica
          </div>
          <div class="display italic text-[22px] leading-tight mt-1">Balayage suau</div>
          <div class="mono-label text-muted mt-1 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full" style="background:#D9A85C"></span>
            <span class="w-3 h-3 rounded-full" style="background:#EFE0C8"></span>
            № 04 · Mel i sorra
          </div>
        </div>

        <!-- Corner tag -->
        <div class="absolute top-4 right-4 bg-linen/90 border hairline-sand px-3 py-2 mono-label" style="color:rgba(28,26,24,0.7)">
          Tardor · '26
        </div>
      </div>
    </div>

    <div class="softline mx-6 md:mx-10"></div>
  </section>

  <!-- ===== SPECIALTY BAR ===== -->
  <section aria-label="Especialitats" class="py-6 md:py-8 border-y hairline bg-cream">
    <div class="max-w-[1360px] mx-auto px-6 md:px-10 grid grid-cols-2 md:grid-cols-4">
      <div class="mono-label flex items-center gap-3 py-3 md:py-2 md:justify-center border-b md:border-b-0 md:border-r hairline" style="color:rgba(28,26,24,0.8)">
        <span class="w-2 h-2 rounded-full bg-terracotta"></span>
        Color i balayage
      </div>
      <div class="mono-label flex items-center gap-3 py-3 md:py-2 md:justify-center border-b md:border-b-0 md:border-r hairline" style="color:rgba(28,26,24,0.8)">
        <span class="w-2 h-2 rounded-full bg-honey"></span>
        Babylights
      </div>
      <div class="mono-label flex items-center gap-3 py-3 md:py-2 md:justify-center md:border-r hairline" style="color:rgba(28,26,24,0.8)">
        <span class="w-2 h-2 rounded-full bg-sage"></span>
        Homes i dones
      </div>
      <div class="mono-label flex items-center gap-3 py-3 md:py-2 md:justify-center" style="color:rgba(28,26,24,0.8)">
        <span class="w-2 h-2 rounded-full bg-blush"></span>
        Nupcial i ocasions
      </div>
    </div>
  </section>

  <!-- ===== COLOUR HIGHLIGHT ===== -->
  <section id="color" class="relative py-20 md:py-32 bg-cream-wash">
    <div class="max-w-[1360px] mx-auto px-6 md:px-10 grid md:grid-cols-12 gap-10 md:gap-16 items-center">

      <!-- Image -->
      <div class="md:col-span-6 relative">
        <div class="aspect-[4/5] w-full overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1562322140-8baeececf3df?w=800&q=80"
            alt="Tècnica de balayage pintada a mà a Maria Gifra &amp; Paula Perruquers"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <!-- "Des de 1967" honey badge -->
        <div class="absolute -right-4 md:-right-8 top-8 md:top-10">
          <div class="w-32 h-32 md:w-40 md:h-40 rounded-full flex flex-col items-center justify-center text-center" style="background:#D9A85C;box-shadow:0 20px 40px -20px rgba(180,106,78,0.55)">
            <div class="mono-label" style="color:rgba(28,26,24,0.7)">Des de</div>
            <div class="display italic text-[44px] md:text-[56px] leading-none text-ink mt-1">1967</div>
            <div class="mono-label" style="color:rgba(28,26,24,0.7)">· Porqueres ·</div>
          </div>
        </div>

        <div class="mt-4 flex justify-between items-center mono-label text-muted">
          <span>Fig. 01 — Aplicació manual</span>
          <span class="hidden sm:inline">Cabell natural · sense decoloració agressiva</span>
        </div>
      </div>

      <!-- Text -->
      <div class="md:col-span-6 md:pl-8">
        <div class="mono-label text-taupe mb-6 flex items-center gap-3">
          <span>01</span>
          <span class="w-10 h-px bg-taupe/60"></span>
          El color de la casa
        </div>

        <h2 class="display text-[48px] md:text-[72px] leading-[1.02]">
          Color que <span class="italic text-terracotta">transforma</span>,
          <br/>sense que es noti la mà.
        </h2>

        <!-- Formula row -->
        <div class="mt-8 flex items-center gap-3 border-y hairline py-4">
          <span class="mono-label text-muted">Fórmula</span>
          <span class="flex -space-x-2">
            <span class="w-7 h-7 rounded-full border-2 border-linen" style="background:#6B3A3A"></span>
            <span class="w-7 h-7 rounded-full border-2 border-linen" style="background:#B46A4E"></span>
            <span class="w-7 h-7 rounded-full border-2 border-linen" style="background:#D9A85C"></span>
            <span class="w-7 h-7 rounded-full border-2 border-linen" style="background:#E8C9BA"></span>
            <span class="w-7 h-7 rounded-full border-2 border-linen" style="background:#EFE0C8"></span>
          </span>
          <span class="ml-auto italic display text-[18px]">Terres d'Empordà</span>
        </div>

        <p class="mt-8 text-[17px] leading-[1.7] max-w-[52ch] font-light" style="color:rgba(28,26,24,0.75)">
          Treballem cada color a mida, llegint la llum, la pell i el cabell
          de cada persona. Balayage, babylights, ombrés suaus o tons
          naturals: tècniques pintades a mà que creixen amb tu i que
          respecten la fibra capil·lar.
        </p>

        <ul class="mt-10 space-y-4 max-w-lg">
          <li class="flex items-start gap-4 border-t hairline pt-4">
            <span class="mono-label text-taupe mt-1">01</span>
            <div>
              <div class="display italic text-[22px]">Diagnòstic i prova de color</div>
              <div class="text-[15px] mt-1" style="color:rgba(28,26,24,0.65)">Sempre comencem amb una conversa i una lectura del cabell.</div>
            </div>
          </li>
          <li class="flex items-start gap-4 border-t hairline pt-4">
            <span class="mono-label text-taupe mt-1">02</span>
            <div>
              <div class="display italic text-[22px]">Pintat a mà, mecha a mecha</div>
              <div class="text-[15px] mt-1" style="color:rgba(28,26,24,0.65)">Moviment natural, transicions sense contrastos durs.</div>
            </div>
          </li>
          <li class="flex items-start gap-4 border-t border-b hairline py-4">
            <span class="mono-label text-taupe mt-1">03</span>
            <div>
              <div class="display italic text-[22px]">Tractament i brillantor final</div>
              <div class="text-[15px] mt-1" style="color:rgba(28,26,24,0.65)">Cura hidratant per fixar el to i segellar la cutícula.</div>
            </div>
          </li>
        </ul>

        <a href="#serveis" class="inline-flex items-center gap-3 mt-10 mono-label text-ink hover:text-taupe transition">
          <span class="w-10 h-px bg-ink"></span>
          Veure totes les tècniques de color
          <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES GRID ===== -->
  <section id="serveis" class="py-20 md:py-32 bg-cream">
    <div class="max-w-[1360px] mx-auto px-6 md:px-10">

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-20">
        <div>
          <div class="mono-label text-taupe mb-5 flex items-center gap-3">
            <span>02</span>
            <span class="w-10 h-px bg-taupe/60"></span>
            Carta de serveis
          </div>
          <h2 class="display text-[48px] md:text-[72px] leading-[1.02] max-w-[16ch]">
            Quatre famílies,
            <span class="italic text-terracotta">una mateixa cura.</span>
          </h2>
        </div>
        <p class="max-w-sm font-light leading-relaxed" style="color:rgba(28,26,24,0.7)">
          Tots els serveis inclouen diagnòstic, rentat amb productes adaptats
          i assessorament a casa. Preus orientatius — confirmem abans de començar.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 border-t border-l hairline">

        <!-- Card 1: Tall i forma -->
        <article class="svc group p-8 md:p-10 border-b border-r hairline relative min-h-[420px] flex flex-col">
          <div class="absolute top-0 left-0 right-0 h-1 bg-sage"></div>
          <div class="flex items-start justify-between">
            <span class="svc-num mono-label text-muted transition-colors">№ 01</span>
            <span class="mono-label text-muted">H · D</span>
          </div>
          <h3 class="display text-[38px] md:text-[44px] leading-[1.05] mt-10">
            <span class="italic" style="color:color-mix(in srgb, #A8B39A 75%, #1C1A18 25%)">Tall i forma</span>
          </h3>
          <ul class="mt-6 space-y-2 text-[15px] font-light" style="color:rgba(28,26,24,0.75)">
            <li class="flex justify-between border-b hairline pb-2"><span>Tall dona</span><span class="mono-label text-muted">28€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Tall home</span><span class="mono-label text-muted">18€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Flequillo / retoc</span><span class="mono-label text-muted">9€</span></li>
            <li class="flex justify-between"><span>Pentinat + brushing</span><span class="mono-label text-muted">22€</span></li>
          </ul>
          <a href="tel:+34972572601" class="reveal mt-auto pt-8 mono-label text-taupe flex items-center gap-2">
            Consultar disponibilitat <span aria-hidden>→</span>
          </a>
        </article>

        <!-- Card 2: Color -->
        <article class="svc group p-8 md:p-10 border-b border-r hairline relative min-h-[420px] flex flex-col">
          <div class="absolute top-0 left-0 right-0 h-1 bg-terracotta"></div>
          <div class="flex items-start justify-between">
            <span class="svc-num mono-label text-muted transition-colors">№ 02</span>
            <span class="mono-label text-muted">Signature</span>
          </div>
          <h3 class="display text-[38px] md:text-[44px] leading-[1.05] mt-10">
            <span class="italic text-terracotta">Color</span>
          </h3>
          <ul class="mt-6 space-y-2 text-[15px] font-light" style="color:rgba(28,26,24,0.75)">
            <li class="flex justify-between border-b hairline pb-2"><span>Balayage</span><span class="mono-label text-muted">des de 85€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Babylights</span><span class="mono-label text-muted">des de 75€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Color natural</span><span class="mono-label text-muted">42€</span></li>
            <li class="flex justify-between"><span>Retoc arrels</span><span class="mono-label text-muted">35€</span></li>
          </ul>
          <a href="tel:+34972572601" class="reveal mt-auto pt-8 mono-label text-taupe flex items-center gap-2">
            Consultar disponibilitat <span aria-hidden>→</span>
          </a>
        </article>

        <!-- Card 3: Tractaments -->
        <article class="svc group p-8 md:p-10 border-b border-r hairline relative min-h-[420px] flex flex-col">
          <div class="absolute top-0 left-0 right-0 h-1 bg-honey"></div>
          <div class="flex items-start justify-between">
            <span class="svc-num mono-label text-muted transition-colors">№ 03</span>
            <span class="mono-label text-muted">Cura</span>
          </div>
          <h3 class="display text-[38px] md:text-[44px] leading-[1.05] mt-10">
            <span class="italic" style="color:color-mix(in srgb, #D9A85C 82%, #1C1A18 18%)">Tractaments</span>
          </h3>
          <ul class="mt-6 space-y-2 text-[15px] font-light" style="color:rgba(28,26,24,0.75)">
            <li class="flex justify-between border-b hairline pb-2"><span>Hidratació profunda</span><span class="mono-label text-muted">18€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Botox capil·lar</span><span class="mono-label text-muted">48€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Ritual anticaiguda</span><span class="mono-label text-muted">32€</span></li>
            <li class="flex justify-between"><span>Queratina</span><span class="mono-label text-muted">des de 85€</span></li>
          </ul>
          <a href="tel:+34972572601" class="reveal mt-auto pt-8 mono-label text-taupe flex items-center gap-2">
            Consultar disponibilitat <span aria-hidden>→</span>
          </a>
        </article>

        <!-- Card 4: Nupcial -->
        <article id="nupcial" class="svc group p-8 md:p-10 border-b border-r hairline relative min-h-[420px] flex flex-col">
          <div class="absolute top-0 left-0 right-0 h-1 bg-blush"></div>
          <div class="flex items-start justify-between">
            <span class="svc-num mono-label text-muted transition-colors">№ 04</span>
            <span class="mono-label text-muted">Ocasions</span>
          </div>
          <h3 class="display text-[38px] md:text-[44px] leading-[1.05] mt-10">
            <span class="italic text-rose">Nupcial</span>
          </h3>
          <ul class="mt-6 space-y-2 text-[15px] font-light" style="color:rgba(28,26,24,0.75)">
            <li class="flex justify-between border-b hairline pb-2"><span>Prova pentinat</span><span class="mono-label text-muted">45€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Pentinat núvia</span><span class="mono-label text-muted">95€</span></li>
            <li class="flex justify-between border-b hairline pb-2"><span>Convidades</span><span class="mono-label text-muted">des de 38€</span></li>
            <li class="flex justify-between"><span>Desplaçament</span><span class="mono-label text-muted">a consultar</span></li>
          </ul>
          <a href="tel:+34972572601" class="reveal mt-auto pt-8 mono-label text-taupe flex items-center gap-2">
            Consultar disponibilitat <span aria-hidden>→</span>
          </a>
        </article>
      </div>

      <p class="mt-8 mono-label text-muted text-center">
        * Preus indicatius segons llargada i densitat del cabell. Consulta sense compromís.
      </p>
    </div>
  </section>

  <!-- ===== QUOTE / STORY ===== -->
  <section id="salo" class="py-20 md:py-32 relative overflow-hidden" style="background:#F6E8DE">
    <div class="max-w-[1100px] mx-auto px-6 md:px-10 text-center">
      <div class="mono-label text-taupe mb-6 flex items-center justify-center gap-3">
        <span class="w-10 h-px bg-taupe/60"></span>
        Una història familiar
        <span class="w-10 h-px bg-taupe/60"></span>
      </div>
      <blockquote class="display text-[32px] md:text-[48px] leading-[1.15] text-ink">
        "Ens van ensenyar que <span class="italic text-terracotta">un bon tall</span>
        s'escolta abans de tocar-lo. Seixanta anys després,
        encara comencem <span class="italic text-terracotta">per la conversa</span>."
      </blockquote>
      <div class="mt-10 flex items-center justify-center gap-4 mono-label text-muted">
        <span>Maria Gifra</span>
        <span class="w-1 h-1 rounded-full bg-sand"></span>
        <span>Paula Perruquers</span>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT / FOOTER ===== -->
  <footer id="contacte" class="bg-cream border-t hairline relative">
    <div class="tape h-1 w-full absolute top-0 left-0 right-0"></div>
    <div class="max-w-[1360px] mx-auto px-6 md:px-10 py-16 md:py-20 grid md:grid-cols-12 gap-10">

      <div class="md:col-span-5">
        <div class="display text-[40px] md:text-[48px] lg:text-[56px] leading-[1.15]">
          Vine a veure'ns
          <br/><span class="italic text-terracotta">a Porqueres.</span>
        </div>
        <p class="mt-8 max-w-sm font-light leading-relaxed" style="color:rgba(28,26,24,0.7)">
          Amb cita prèvia per dedicar-te el temps que et mereixes.
          T'esperem amb un cafè abans de començar.
        </p>
        <a href="tel:+34972572601"
           class="inline-flex flex-col items-start gap-0.5 mt-8 bg-terracotta text-linen px-6 py-4 hover:bg-ink transition">
