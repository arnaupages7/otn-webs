---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'

const serveis = [
  {
    nom: 'Tall de cabell',
    tecnica: 'Analitzem la forma del rostre, la textura del cabell i l\'estil de vida de la client abans de tallar. Usem la tècnica de tall en humit per a cabells llisos i tall en sec per a cabells ondulats o rissats, respectant el moviment natural de cada cabell. El resultat és un tall que creix bé i és fàcil de mantenir a casa.',
    foto: 'https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=800&q=80',
    alt: 'Tall de cabell professional',
  },
  {
    nom: 'Tall i assecada',
    tecnica: 'El servei inclou el tall personalitzat més una assecada professional amb secador i raspall rodó. Modelem el cabell donant volum a les arrels i lluentor a les puntes. Ideal per a ocasions especials o per estrenar un look impecable.',
    foto: 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=80',
    alt: 'Assecada professional amb secador',
  },
  {
    nom: 'Tall d\'home',
    tecnica: 'Tall clàssic o modern adaptat al tipus de cabell i preferències. Treballem amb tisores i màquina, definint el perfil i la nuca amb precisió. Acabat amb producte de fixació si el client ho desitja.',
    foto: 'https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=800&q=80',
    alt: 'Tall d\'home professional',
  },
  {
    nom: 'Franja i bigoti',
    tecnica: 'Retoc i perfilat de barba, franja i bigoti amb tisores i navalla. Definim les línies del rostre accentuant els trets masculins. Un servei ràpid i precís per mantenir un aspecte cuidat entre tallades.',
    foto: 'https://images.unsplash.com/photo-1621605815971-fbc98d665033?w=800&q=80',
    alt: 'Retoc de barba i franja',
  },
]
---

<Layout
  title="Tall i forma — Maria Gifra & Paula Perruquers"
  description="Serveis de tall de cabell professional a Porqueres. Tall de cabell, tall i assecada, tall d'home i franja. Tècniques adaptades a cada cabell i rostre."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-[50vh] flex items-center justify-center pt-16 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('https://images.unsplash.com/photo-1633681122188-3abb9e835a3a?w=1600&q=80'), linear-gradient(135deg, #1a1514 0%, #4a3a37 100%); filter: brightness(0.3);"
    ></div>
    <div class="relative z-10 text-center px-4 max-w-3xl">
      <a href="/#serveis" class="text-brand-300 text-sm font-medium tracking-widest uppercase mb-4 inline-block hover:text-brand-200 transition-colors">
        ← Tots els serveis
      </a>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-white leading-tight mb-4 mt-2">
        Tall i forma
      </h1>
      <p class="text-brand-200/80 text-lg max-w-xl mx-auto">
        El tall perfecte comença per entendre qui ets. Cada cabell és diferent, cada tall és únic.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-16 bg-warm-50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-brand-500 font-semibold text-sm tracking-widest uppercase mb-4">La nostra filosofia</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-warm-900 mb-6">
        Un tall que et representi
      </h2>
      <p class="text-warm-800/70 text-lg leading-relaxed">
        Abans de tallar, parlem. Entenem la teva rutina, el temps que dediques al cabell cada matí,
        el teu estil. Amb aquesta informació, creem un tall adaptat a tu que sigui bonic acabat de fer
        i fàcil de mantenir a casa.
      </p>
    </div>
  </section>

  <!-- SERVEIS GRID -->
  <section class="py-16 bg-warm-100">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-10">
        {serveis.map((s) => (
          <div class="bg-warm-50 rounded-2xl overflow-hidden shadow-sm border border-brand-100">
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={s.foto}
                alt={s.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-8">
              <h3 class="font-display text-2xl font-bold text-warm-900 mb-3">{s.nom}</h3>
              <p class="text-warm-800/70 leading-relaxed">{s.tecnica}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand-800 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Llest per un canvi?</h2>
      <p class="text-brand-200/70 mb-8">Truca'ns i t'assessorem sense compromís.</p>
      <a
        href="tel:+34972572601"
        class="inline-flex items-center justify-center bg-white text-brand-800 px-8 py-4 rounded-xl text-lg font-semibold hover:bg-brand-100 transition-colors"
      >
        Demanar cita — 972 572 601
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand-900 text-brand-200/50 py-8">
    <div class="max-w-6xl mx-auto px-4 text-center text-sm">
      <p class="font-display text-brand-300 text-lg mb-2 italic">Maria Gifra & Paula Perruquers</p>
      <p>Carrer de les Pedreres, 19 · 17182 Porqueres · 972 572 601</p>
      <p class="mt-4 text-brand-200/30">&copy; {new Date().getFullYear()} Maria Gifra & Paula Perruquers.</p>
    </div>
  </footer>

  <!-- MOBILE CTA -->
  <div class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
    <a
      href="tel:+34972572601"
      class="bg-brand-700 text-white px-8 py-4 rounded-full text-lg font-bold shadow-2xl hover:bg-brand-800 transition-colors flex items-center gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      Demanar cita
    </a>
  </div>
</Layout>
