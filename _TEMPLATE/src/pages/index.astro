---
import Layout from '../layouts/Layout.astro'

// TODO: substituir per dades del client
const NEGOCI = {
  nom: 'Nom del Negoci',
  tagline: 'Tagline curt que descriu el que fas',
  telefon: '+34 600 000 000',
  email: 'hola@elteunegoci.cat',
  adreca: 'Carrer X, 00 · Població · CP',
}
---

<Layout
  title={`${NEGOCI.nom} · ${NEGOCI.tagline}`}
  description={NEGOCI.tagline}
>
  <main class="min-h-screen">
    <section class="px-6 py-32 max-w-4xl mx-auto">
      <h1 class="font-display text-6xl md:text-8xl mb-6">
        {NEGOCI.nom}
      </h1>
      <p class="text-2xl text-cream/80 mb-12">
        {NEGOCI.tagline}
      </p>

      <div class="space-y-2 text-lg">
        <p>📞 <a href={`tel:${NEGOCI.telefon}`} class="hover:text-accent">{NEGOCI.telefon}</a></p>
        <p>✉️ <a href={`mailto:${NEGOCI.email}`} class="hover:text-accent">{NEGOCI.email}</a></p>
        <p>📍 {NEGOCI.adreca}</p>
      </div>
    </section>
  </main>
</Layout>
