---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Stats from '../../components/Stats.astro'
import TwoPaths from '../../components/TwoPaths.astro'
import HowItWorks from '../../components/HowItWorks.astro'
import Providers from '../../components/Providers.astro'

import SocialRides from '../../components/SocialRides.astro'
import Problem from '../../components/Problem.astro'
import VeloTribeStandard from '../../components/VeloTribeStandard.astro'
import Waitlist from '../../components/Waitlist.astro'
import WeekendBanner from '../../components/WeekendBanner.astro'
import QuoteHero from '../../components/QuoteHero.astro'
import Footer from '../../components/Footer.astro'

const lang = 'fr' as const
---

<Layout
  lang={lang}
  title="VeloTribe — Cyclisme à Gérone, fait pour la tribu"
  description="La plateforme pour les cyclistes qui roulent à Gérone — et les locaux qui les accueillent. Rejoignez la liste d'attente."
>
  <Nav lang={lang} />
  <QuoteHero lang={lang} />
  <WeekendBanner lang={lang} />
  <Stats lang={lang} />
  <Problem lang={lang} />
  <TwoPaths lang={lang} />
  <HowItWorks lang={lang} />
  <Providers lang={lang} />
  <VeloTribeStandard lang={lang} />
  <SocialRides lang={lang} />
  
  <Waitlist lang={lang} />
  <Footer lang={lang} />
</Layout>
