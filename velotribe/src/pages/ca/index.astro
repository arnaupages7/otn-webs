---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Hero from '../../components/Hero.astro'
import Stats from '../../components/Stats.astro'
import TwoPaths from '../../components/TwoPaths.astro'
import HowItWorks from '../../components/HowItWorks.astro'
import Problem from '../../components/Problem.astro'
import Waitlist from '../../components/Waitlist.astro'
import Providers from '../../components/Providers.astro'
import Footer from '../../components/Footer.astro'

const lang = 'ca' as const
---

<Layout
  lang={lang}
  title="VeloTribe — Ciclisme a Girona, fet per la tribu"
  description="La plataforma pels ciclistes que pedalen per Girona — i els amfitrions locals que els acullen. Apunta't a la llista d'espera."
>
  <Nav lang={lang} />
  <Hero lang={lang} />
  <Stats lang={lang} />
  <TwoPaths lang={lang} />
  <HowItWorks lang={lang} />
  <Problem lang={lang} />
  <Waitlist lang={lang} />
  <Providers lang={lang} />
  <Footer lang={lang} />
</Layout>
