---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Hero from '../../components/Hero.astro'
import Stats from '../../components/Stats.astro'
import TwoPaths from '../../components/TwoPaths.astro'
import HowItWorks from '../../components/HowItWorks.astro'
import Problem from '../../components/Problem.astro'
import VeloTribeStandard from '../../components/VeloTribeStandard.astro'
import Waitlist from '../../components/Waitlist.astro'
import Providers from '../../components/Providers.astro'
import Footer from '../../components/Footer.astro'

const lang = 'es' as const
---

<Layout
  lang={lang}
  title="VeloTribe — Ciclismo en Girona, hecho para la tribu"
  description="La plataforma para los ciclistas que pedalean por Girona — y los locales que los acogen. Únete a la lista de espera."
>
  <Nav lang={lang} />
  <Hero lang={lang} />
  <Stats lang={lang} />
  <TwoPaths lang={lang} />
  <HowItWorks lang={lang} />
  <Problem lang={lang} />
  <VeloTribeStandard lang={lang} />
  <Waitlist lang={lang} />
  <Providers lang={lang} />
  <Footer lang={lang} />
</Layout>
