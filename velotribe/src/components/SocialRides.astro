---
import { pathFor, type Lang } from '../i18n/utils'
import { rides, type Difficulty } from '../data/rides'

interface Props { lang: Lang }
const { lang } = Astro.props

const labels = {
  en: {
    eyebrow: 'Ride with us',
    title: 'Social rides',
    sub: 'Real group rides, real roads, real people. Limited spots — first come, first served.',
    spots: 'spots left',
    spot: 'spot left',
    full: 'Full',
    km: 'km',
    m: 'm↑',
    join: 'Reserve my spot',
    difficulty: { easy: 'Easy', medium: 'Medium', hard: 'Hard' },
  },
  es: {
    eyebrow: 'Rueda con nosotros',
    title: 'Salidas sociales',
    sub: 'Salidas en grupo reales, carreteras reales, gente real. Plazas limitadas — por orden de llegada.',
    spots: 'plazas libres',
    spot: 'plaza libre',
    full: 'Completo',
    km: 'km',
    m: 'm↑',
    join: 'Reservar mi plaza',
    difficulty: { easy: 'Fácil', medium: 'Medio', hard: 'Duro' },
  },
  ca: {
    eyebrow: 'Pedala amb nosaltres',
    title: 'Sortides socials',
    sub: 'Sortides en grup reals, carreteres reals, gent real. Places limitades — per ordre d\'arribada.',
    spots: 'places lliures',
    spot: 'plaça lliure',
    full: 'Complet',
    km: 'km',
    m: 'm↑',
    join: 'Reservar la meva plaça',
    difficulty: { easy: 'Fàcil', medium: 'Mig', hard: 'Dur' },
  },
  fr: {
    eyebrow: 'Roulez avec nous',
    title: 'Sorties sociales',
    sub: 'De vraies sorties en groupe, de vraies routes, de vraies personnes. Places limitées — premier arrivé, premier servi.',
    spots: 'places restantes',
    spot: 'place restante',
    full: 'Complet',
    km: 'km',
    m: 'm↑',
    join: 'Réserver ma place',
    difficulty: { easy: 'Facile', medium: 'Moyen', hard: 'Difficile' },
  },
}

const t = labels[lang] ?? labels.en

const difficultyColors: Record<Difficulty, string> = {
  easy:   '#6db87a',
  medium: '#d4a843',
  hard:   '#d46060',
}

function formatDate(iso: string, l: Lang): string {
  const d = new Date(iso + 'T12:00:00')
  const locales: Record<string, string> = { en: 'en-GB', es: 'es-ES', ca: 'ca-ES', fr: 'fr-FR' }
  return d.toLocaleDateString(locales[l] ?? 'en-GB', { weekday: 'short', day: 'numeric', month: 'long' })
}

const waitlistHref = lang === 'en' ? '/#waitlist' : `/${lang}/#waitlist`

const ridesData = rides.map(ride => ({
  ...ride,
  isFull: ride.spotsLeft === 0,
  isUrgent: ride.spotsLeft > 0 && ride.spotsLeft < 4,
  spotsLabel: ride.spotsLeft === 1 ? t.spot : t.spots,
  titleLoc: ride.title[lang as 'en'|'es'|'ca'|'fr'] ?? ride.title.en,
  diffLabel: t.difficulty[ride.difficulty],
  diffColor: difficultyColors[ride.difficulty],
  day: new Date(ride.date + 'T12:00:00').getDate(),
  month: new Date(ride.date + 'T12:00:00').toLocaleDateString('en', { month: 'short' }),
}))
---

<section class="px-[5vw] py-20" style="background:#F8EEDA">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <p class="text-[11px] font-bold tracking-[3px] uppercase mb-2.5" style="color:#A7B75D">{t.eyebrow}</p>
      <h2 class="font-display font-black uppercase leading-[0.95] mb-4" style="color:#41372B;font-size:clamp(32px,6vw,58px)">{t.title}</h2>
      <p class="text-base max-w-md mx-auto" style="color:#9a8c7a">{t.sub}</p>
    </div>

    <!-- Rides -->
    <div class="flex flex-col gap-4 reveal">
      {ridesData.map(ride => (
        <div class="rounded-2xl overflow-hidden flex flex-col sm:flex-row relative" style="background:#41372B">

          {ride.comingSoon ? (
            <>
              <!-- Contingut borrós -->
              <div class="flex flex-col sm:flex-row w-full" style="filter:blur(5px);user-select:none;pointer-events:none">
                <div class="flex flex-col items-center justify-center px-6 py-5 sm:py-0 shrink-0 sm:w-28" style="background:#2C2419">
                  <span class="font-display font-black text-2xl uppercase leading-none" style="color:#F8EEDA">{ride.day}</span>
                  <span class="text-xs uppercase tracking-wider mt-0.5" style="color:#A7B75D">{ride.month}</span>
                </div>
                <div class="flex flex-col sm:flex-row flex-1 items-start sm:items-center gap-4 px-6 py-5">
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <h3 class="font-display font-black text-lg uppercase" style="color:#F8EEDA">Girona Mystery Ride</h3>
                      <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full" style="background:#A7B75D22;color:#A7B75D;border:1px solid #A7B75D44">Hard</span>
                    </div>
                    <p class="text-xs mb-2" style="color:#ffffff55">Girona · ??? · Girona</p>
                    <div class="flex flex-wrap gap-3 text-xs" style="color:#ffffff70">
                      <span>📍 Girona</span>
                      <span>⬤ ??? km</span>
                      <span>▲ ??? m↑</span>
                    </div>
                  </div>
                  <div class="flex flex-col items-end gap-2 shrink-0">
                    <span class="text-xs font-bold px-3 py-1 rounded-full" style="background:#A7B75D22;color:#A7B75D;border:1px solid #A7B75D44">12 spots</span>
                    <span class="inline-flex items-center text-xs font-bold px-4 py-2 rounded-lg" style="background:#A7B75D;color:#2C2419">Reserve →</span>
                  </div>
                </div>
              </div>
              <!-- Overlay Coming Soon -->
              <div class="absolute inset-0 flex items-center justify-between px-6" style="background:#2C2419cc">
                <!-- Data visible -->
                <div class="flex flex-col items-center shrink-0 w-20">
                  <span class="font-display font-black text-4xl leading-none" style="color:#F8EEDA">{ride.day}</span>
                  <span class="text-sm uppercase tracking-widest mt-1 font-bold" style="color:#A7B75D">{ride.month}</span>
                </div>
                <!-- Coming soon + CTA -->
                <div class="flex flex-col items-center gap-3 flex-1">
                  <span class="font-display font-black text-2xl uppercase tracking-widest" style="color:#F8EEDA">Coming Soon</span>
                  <a href={waitlistHref} class="text-xs font-bold px-4 py-2 rounded-lg transition hover:opacity-90" style="background:#A7B75D;color:#2C2419">
                    Join the waitlist →
                  </a>
                </div>
                <div class="w-20 shrink-0"></div>
              </div>
            </>
          ) : (
            <>
              <div class="flex flex-col items-center justify-center px-6 py-5 sm:py-0 shrink-0 sm:w-28" style="background:#2C2419">
                <span class="font-display font-black text-2xl uppercase leading-none" style="color:#F8EEDA">{ride.day}</span>
                <span class="text-xs uppercase tracking-wider mt-0.5" style="color:#A7B75D">{ride.month}</span>
                <span class="text-xs mt-2" style="color:#ffffff50">{ride.time}h</span>
              </div>
              <div class="flex flex-col sm:flex-row flex-1 items-start sm:items-center gap-4 px-6 py-5">
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <h3 class="font-display font-black text-lg uppercase" style="color:#F8EEDA">{ride.titleLoc}</h3>
                    <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full"
                      style={`background:${ride.diffColor}22;color:${ride.diffColor};border:1px solid ${ride.diffColor}44`}>
                      {ride.diffLabel}
                    </span>
                  </div>
                  <p class="text-xs mb-2" style="color:#ffffff55">{ride.route}</p>
                  <div class="flex flex-wrap gap-3 text-xs" style="color:#ffffff70">
                    <span>📍 {ride.meetPoint}</span>
                    <span>⬤ {ride.distance}{t.km}</span>
                    <span>▲ {ride.elevation}{t.m}</span>
                  </div>
                </div>
                <div class="flex flex-col items-start sm:items-end gap-2 shrink-0">
                  {ride.isFull ? (
                    <span class="text-xs font-bold px-3 py-1 rounded-full" style="background:#d4606022;color:#d46060;border:1px solid #d4606044">{t.full}</span>
                  ) : (
                    <>
                      <span class="text-xs font-bold px-3 py-1 rounded-full"
                        style={ride.isUrgent ? 'background:#d4a84322;color:#d4a843;border:1px solid #d4a84344' : 'background:#A7B75D22;color:#A7B75D;border:1px solid #A7B75D44'}>
                        {ride.isUrgent && '⚡ '}{ride.spotsLeft} {ride.spotsLabel}
                      </span>
                      <a href={waitlistHref} class="inline-flex items-center gap-1.5 text-xs font-bold px-4 py-2 rounded-lg transition hover:gap-2.5" style="background:#A7B75D;color:#2C2419">
                        {t.join} →
                      </a>
                    </>
                  )}
                </div>
              </div>
            </>
          )}

        </div>
      ))}
    </div>

  </div>
</section>
