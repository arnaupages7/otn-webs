      },
      {
        day: 'Jour 2',
        label: 'Samedi · 6 sept',
        title: 'La grande sortie',
        icon: '🚵',
        color: '#A7B75D',
        img: '/weekend/gravel-1.jpg',
        items: [
          { time: '07:30', desc: 'Petit-déjeuner cycliste à Cal Santu avec produits locaux.' },
          { time: '08:30', desc: "Sortie gravel principale. Forêts du Pla de l'Estany, sentiers volcaniques de la Garrotxa. ~60km · 900m+." },
          { time: '13:30', desc: 'Déjeuner dans un restaurant de village.' },
          { time: 'Après-midi', desc: 'Retour à Cal Santu. Piscine, récupération, temps libre.' },
          { time: 'Soir', desc: 'Dîner en groupe à la maison. Histoires de la route.' },
        ],
      },
      {
        day: 'Jour 3',
        label: 'Dimanche · 7 sept',
        title: 'Sortie matinale + au revoir',
        icon: '🌄',
        color: '#A7B75D',
        img: '/weekend/gravel-4.jpg',
        items: [
          { time: '07:30', desc: 'Petit-déjeuner à Cal Santu.' },
          { time: '08:30', desc: 'Boucle gravel autour du lac de Banyoles. Parcours plus léger — ~35km · 400m+.' },
          { time: '11:30', desc: 'Retour, douche, bagages.' },
          { time: '13:00', desc: "Déjeuner d'au revoir en groupe." },
          { time: 'Après-midi', desc: "Transfert retour vers l'aéroport de Gérone ou Barcelone." },
        ],
      },
    ],

    ridesTitle: 'Le gravel',
    ridesSub: "Banyoles et le Pla de l'Estany sont au carrefour de trois mondes : forêt volcanique, contreforts de montagne et pays des lacs. Territoire gravel pur.",
    route1Title: "Pla de l'Estany & Garrotxa",
    route1Stats: '60 km · 900 m↑ · Terrain mixte',
    route1Desc: "Depuis Cal Santu, s'enfoncer dans les forêts du Pla de l'Estany — pistes de terre entre chênes centenaires, sans voitures, sans bruit. Pénétrer dans la zone volcanique de la Garrotxa : hêtraies, cônes de lave, villages cachés. Retour par le lac de Banyoles.",
    route2Title: 'Boucle lac de Banyoles',
    route2Stats: '35 km · 400 m↑ · Gravel et bitume',
    route2Desc: "Une boucle matinale plus courte et douce. Longer le lac Olympique, monter sur les collines au-dessus de Porqueres, rouler dans les champs de maïs avec les Pyrénées à l'horizon. La sortie d'adieu parfaite.",

    houseTitle: 'Où vous logez',
    houseName: 'Cal Santu',
    houseSub: "Une ferme en pierre du XVIIIe siècle entièrement rénovée. 5 chambres, piscine, terrasse couverte, cuisine pour 14. À 10 min du lac de Banyoles.",
    houseFeatures: [
      { icon: '🏊', label: 'Piscine privée' },
      { icon: '🍽️', label: 'Cuisine complète' },
      { icon: '🛏️', label: '5 chambres' },
      { icon: '🚲', label: 'Garage vélos' },
      { icon: '🌿', label: 'Jardin & terrasse' },
      { icon: '🌄', label: 'Vue montagne' },
    ],

    includedTitle: 'Ce qui est inclus',
    includedSub: 'Vous arrivez. On s\'occupe du reste.',
    included: [
      { icon: '🏡', title: 'Hébergement', desc: 'Deux nuits à Cal Santu en chambres privées.' },
      { icon: '🚲', title: 'Sorties gravel guidées', desc: 'Les deux jours guidés par des experts locaux qui connaissent chaque sentier.' },
      { icon: '🍳', title: 'Petit-déjeuner cycliste', desc: 'Les deux matins : vrai carburant avec produits locaux.' },
      { icon: '✈️', title: 'Transfert aéroport', desc: "Aéroport de Gérone ou Barcelone — vous et votre vélo." },
      { icon: '📍', title: 'Fichiers GPX', desc: 'Tous les parcours sur votre appareil avant votre arrivée.' },
      { icon: '🤝', title: 'Petit groupe', desc: 'Max. 10 cyclistes. Vraie communauté, pas un bus touristique.' },
      { icon: '🚴', title: 'Location de vélo disponible', desc: 'Pas de vélo ? Nous pouvons en organiser un en location moyennant un supplément.' },
      { icon: '🛏️', title: 'Chambres doubles (option single)', desc: 'Les chambres sont des doubles partagées. Vous souhaitez la chambre pour vous seul(e) ? Un supplément chambre individuelle s\'applique.' },
    ],

    locationTitle: 'Banyoles',
    locationSub: 'Le secret cycliste de Gérone',
    locationText1: "Banyoles est situé dans le Pla de l'Estany — un plateau plat et tranquille entouré de forêts et de champs, avec les Pyrénées au nord. Le lac Olympique — site des Jeux de Barcelone 1992 — est à 10 minutes de Cal Santu.",
    locationText2: "D'ici, le gravel de premier niveau est littéralement à la porte. La Garrotxa volcanique commence à 20 minutes à l'ouest. Rocacorba est à 15 minutes au sud. La Costa Brava à 45 minutes à l'est. Gérone à 25 minutes.",
    locationStats: [
      { value: '10\'', label: 'lac de Banyoles' },
      { value: '20\'', label: 'gravel Garrotxa' },
      { value: '25\'', label: 'ville de Gérone' },
      { value: '15\'', label: 'Rocacorba' },
    ],

    contactEyebrow: 'Réserver ce voyage',
    contactTitle: 'Roulez avec la tribu',
    contactSub: "Dites-nous qui vous êtes et combien vous êtes. Nous vous répondons avec tous les détails et le tarif sous 48h.",
    labelName: 'Votre nom',
    labelEmail: 'Email',
    labelParticipants: 'Nombre de cyclistes',
    selectParticipants: 'Sélectionner',
    labelNotes: 'Questions ou notes (optionnel)',
    submit: 'Envoyer la demande',
    sending: 'Envoi…',
    successTitle: 'Demande reçue !',
    successSub: 'Nous vous répondrons avec le tarif et les disponibilités sous 48 heures.',
    errorRequired: 'Merci de renseigner votre nom, email et nombre de participants.',
    errorGeneric: 'Quelque chose s\'est mal passé. Écrivez-nous à hello@velotribe.com.',
    spotsNotice: 'Limité à 10 cyclistes. Le week-end se remplit vite.',
    legalNote: "En envoyant vous acceptez d'être contacté(e) au sujet du VeloTribe Weekend.",
  },
