    heroTitle1: 'VeloTribe',
    heroTitle2: 'Weekend',
    heroTagline: 'Trois jours. Gravel pur. Une tribu.',
    heroSub: "Un week-end gravel tout compris au cœur du Pla de l'Estany. Arrivée vendredi, deux jours à rouler, repartez avec des souvenirs qui durent.",
    heroCta: 'Réserver ce voyage',
    heroScroll: 'Découvrez ce qui vous attend',

    whatTitle: "Qu'est-ce que VeloTribe Weekend ?",
    whatSub: "Une escapade gravel entièrement organisée — tout prévu de l'aéroport à la selle.",
    whatCards: [
      { icon: '🚲', title: 'Gravel pur', desc: "Deux jours de sorties gravel guidées dans le Pla de l'Estany et la zone volcanique de la Garrotxa. Parcours adaptés à votre niveau." },
      { icon: '🏡', title: 'Cal Santu', desc: "Une ferme en pierre du XVIIIe siècle entièrement rénovée. Piscine, grande terrasse, cuisine complète. Votre camp de base pour le week-end." },
      { icon: '👥', title: 'Max. 10 cyclistes', desc: "Petit groupe intentionnel. Vous connaîtrez tout le monde dès vendredi soir. Des échanges vrais, une vraie communauté." },
