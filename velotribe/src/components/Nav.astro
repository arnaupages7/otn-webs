---
import { useTranslations, pathFor, type Lang } from '../i18n/utils'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)

const path = Astro.url.pathname.replace(/^\/(es|ca)/, '') || '/'
---

<nav class="fixed top-0 inset-x-0 z-50 px-[5vw] flex items-center justify-between border-b border-white/10" style="background:#2C2419;color:#F8EEDA;height:60px">
  <a href={pathFor(lang, '/')} class="flex items-center gap-2.5">
    <img src="/logo.png" alt="VeloTribe" class="h-8 w-auto" />
    <span class="font-display font-black tracking-[3px] text-sm">VELOTRIBE</span>
  </a>

  <div class="flex items-center gap-3 md:gap-4">
    <div class="flex items-center gap-1 text-xs font-semibold">
      <a href={path} class:list={['px-2.5 py-1 rounded border transition', lang === 'en' ? 'border-[#A7B75D] text-[#A7B75D]' : 'border-white/20 text-white/60 hover:text-white']}>EN</a>
      <a href={`/es${path}`} class:list={['px-2.5 py-1 rounded border transition', lang === 'es' ? 'border-[#A7B75D] text-[#A7B75D]' : 'border-white/20 text-white/60 hover:text-white']}>ES</a>
      <a href={`/ca${path}`} class:list={['px-2.5 py-1 rounded border transition', lang === 'ca' ? 'border-[#A7B75D] text-[#A7B75D]' : 'border-white/20 text-white/60 hover:text-white']}>CA</a>
    </div>
    <a href="#waitlist" class="px-4 py-2 rounded-md font-bold text-xs uppercase tracking-wider transition hover:opacity-90" style="background:#A7B75D;color:#2C2419">
      {t('nav.cta')}
    </a>
  </div>
</nav>
