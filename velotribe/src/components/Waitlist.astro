---
import { useTranslations, type Lang } from '../i18n/utils'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)
---

<section id="waitlist" class="px-[5vw] py-20" style="background:#F8EEDA">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12 reveal">
      <p class="text-[11px] font-bold tracking-[3px] uppercase mb-2.5" style="color:#A7B75D">{t('wl.eyebrow')}</p>
      <h2 class="font-display font-black uppercase leading-[0.95]" style="color:#41372B;font-size:clamp(32px, 6vw, 58px)" set:html={t('wl.title')}></h2>
      <p class="text-base mt-4 max-w-md mx-auto" style="color:#9a8c7a">{t('wl.sub')}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 reveal">
      <!-- CYCLIST FORM -->
      <form class="rounded-xl p-7 md:p-9 wl-form" data-audience="cyclist" style="background:#41372B" novalidate>
        <span class="inline-block px-3 py-1 rounded text-[10px] font-bold uppercase tracking-[2px] mb-3" style="background:#A7B75D;color:#2C2419">{t('wl.cyclist.title')}</span>
        <h3 class="font-display font-black text-2xl uppercase mb-2" style="color:#F8EEDA">{t('wl.cyclist.title')}</h3>
        <p class="text-sm mb-6" style="color:#ffffff99">{t('wl.cyclist.desc')}</p>

        <div class="flex flex-col gap-3">
          <input
            name="email" type="email" required
            placeholder={t('form.email')}
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border outline-none transition focus:border-[#A7B75D]"
            style="background:#ffffff10;border-color:#ffffff20;color:#F8EEDA" />

          <select name="cycling_type" required class="w-full px-4 py-3 rounded-lg border outline-none transition cursor-pointer" style="background:#ffffff10;border-color:#ffffff20;color:#F8EEDA">
            <option value="" disabled selected>{t('form.cycling_type')}</option>
            <option value="road">{t('form.cycling_type.road')}</option>
            <option value="gravel">{t('form.cycling_type.gravel')}</option>
            <option value="mtb">{t('form.cycling_type.mtb')}</option>
            <option value="all">{t('form.cycling_type.all')}</option>
          </select>

          <label class="flex items-start gap-2 text-xs mt-2 cursor-pointer" style="color:#ffffff99">
            <input type="checkbox" name="consent" required class="mt-0.5" />
            <span set:html={t('consent.cyclist')}></span>
          </label>

          <input type="hidden" name="audience" value="cyclist" />
          <input type="hidden" name="locale" value={lang} />
          <input type="hidden" name="utm_source" data-utm="utm_source" />
          <input type="hidden" name="utm_medium" data-utm="utm_medium" />
          <input type="hidden" name="utm_campaign" data-utm="utm_campaign" />

          <button type="submit" disabled class="w-full py-3.5 rounded-lg font-bold text-sm transition disabled:opacity-50 disabled:cursor-not-allowed mt-2" style="background:#A7B75D;color:#2C2419">
            {t('cyclist.cta')} →
          </button>

          <p class="text-[11px] text-center mt-1" style="color:#ffffff60">{t('form.note')}</p>
          <p class="text-xs text-center mt-1 hidden" data-error style="color:#e57373"></p>
        </div>
      </form>

      <!-- HOST FORM -->
      <form class="rounded-xl p-7 md:p-9 wl-form border-2" data-audience="host" style="background:#494B30;border-color:#A7B75D44" novalidate>
        <span class="inline-block px-3 py-1 rounded text-[10px] font-bold uppercase tracking-[2px] mb-3" style="background:#F8EEDA;color:#41372B">{t('wl.host.title')}</span>
        <h3 class="font-display font-black text-2xl uppercase mb-2" style="color:#F8EEDA">{t('wl.host.title')}</h3>
        <p class="text-sm mb-6" style="color:#ffffff99">{t('wl.host.desc')}</p>

        <div class="flex flex-col gap-3">
          <input name="email" type="email" required placeholder={t('form.email')} autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border outline-none transition focus:border-[#A7B75D]"
            style="background:#ffffff10;border-color:#ffffff20;color:#F8EEDA" />

          <input name="business_name" type="text" required placeholder={t('form.business_name')}
            class="w-full px-4 py-3 rounded-lg border outline-none transition focus:border-[#A7B75D]"
            style="background:#ffffff10;border-color:#ffffff20;color:#F8EEDA" />

          <select name="business_type" required class="w-full px-4 py-3 rounded-lg border outline-none transition cursor-pointer" style="background:#ffffff10;border-color:#ffffff20;color:#F8EEDA">
            <option value="" disabled selected>{t('form.business_type')}</option>
            <option value="accommodation">{t('form.business_type.accommodation')}</option>
            <option value="guide">{t('form.business_type.guide')}</option>
            <option value="tour">{t('form.business_type.tour')}</option>
            <option value="event">{t('form.business_type.event')}</option>
            <option value="other">{t('form.business_type.other')}</option>
          </select>

          <input name="location" type="text" required placeholder={t('form.location')}
            class="w-full px-4 py-3 rounded-lg border outline-none transition focus:border-[#A7B75D]"
            style="background:#ffffff10;border-color:#ffffff20;color:#F8EEDA" />

          <label class="flex items-start gap-2 text-xs mt-2 cursor-pointer" style="color:#ffffff99">
            <input type="checkbox" name="consent" required class="mt-0.5" />
            <span set:html={t('consent.host')}></span>
          </label>

          <input type="hidden" name="audience" value="host" />
          <input type="hidden" name="locale" value={lang} />
          <input type="hidden" name="utm_source" data-utm="utm_source" />
          <input type="hidden" name="utm_medium" data-utm="utm_medium" />
          <input type="hidden" name="utm_campaign" data-utm="utm_campaign" />

          <button type="submit" disabled class="w-full py-3.5 rounded-lg font-bold text-sm transition disabled:opacity-50 disabled:cursor-not-allowed mt-2" style="background:#F8EEDA;color:#41372B">
            {t('host.cta')} →
          </button>

          <p class="text-[11px] text-center mt-1" style="color:#ffffff60">{t('form.note')}</p>
          <p class="text-xs text-center mt-1 hidden" data-error style="color:#e57373"></p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  // Capturar UTMs de la URL
  const params = new URLSearchParams(window.location.search)
  document.querySelectorAll<HTMLInputElement>('[data-utm]').forEach((el) => {
    const key = el.dataset.utm!
    el.value = params.get(key) ?? ''
  })

  // Habilitar submit només quan consent està marcat
  document.querySelectorAll<HTMLFormElement>('form.wl-form').forEach((form) => {
    const checkbox = form.querySelector<HTMLInputElement>('input[name="consent"]')!
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]')!
    const errorEl = form.querySelector<HTMLElement>('[data-error]')!

    function syncEnabled() {
      const requiredFields = Array.from(form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]'))
      const allFilled = requiredFields.every((f) => {
        if (f.type === 'checkbox') return (f as HTMLInputElement).checked
        return f.value.trim() !== ''
      })
      button.disabled = !allFilled
    }

    form.addEventListener('input', syncEnabled)
    form.addEventListener('change', syncEnabled)

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      button.disabled = true
      errorEl.classList.add('hidden')

      const fd = new FormData(form)
      const payload: Record<string, unknown> = {}
      fd.forEach((v, k) => { payload[k] = v })
      payload.consent = checkbox.checked

      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        })
        const data = await res.json() as { ok: boolean; position?: number; error?: string }

        if (!res.ok || !data.ok) {
          errorEl.textContent = data.error || 'error'
          errorEl.classList.remove('hidden')
          syncEnabled()
          return
        }

        const lang = (payload.locale as string) || 'en'
        const prefix = lang === 'en' ? '' : `/${lang}`
        const audience = (payload.audience as string)
        const email = encodeURIComponent(payload.email as string)
        window.location.href = `${prefix}/thanks?n=${data.position}&a=${audience}&e=${email}`
      } catch (err) {
        errorEl.textContent = 'Network error. Please try again.'
        errorEl.classList.remove('hidden')
        syncEnabled()
      }
    })
  })
</script>

<style>
  /* Select option styling for dark backgrounds */
  select option { background: #41372B; color: #F8EEDA; }
</style>
