---
import { pathFor, type Lang } from '../i18n/utils'

interface Props { lang: Lang }
const { lang } = Astro.props

const labels = {
  en: {
    eyebrow: 'The community',
    title: 'Where we ride',
    sub: 'Our hosts dot the roads around Girona — the cycling capital of Europe.',
    viewHost: 'View host',
  },
  es: {
    eyebrow: 'La comunidad',
    title: 'Donde rodamos',
    sub: 'Nuestros anfitriones están repartidos por las carreteras de Girona — la capital europea del ciclismo.',
    viewHost: 'Ver anfitrión',
  },
  ca: {
    eyebrow: 'La comunitat',
    title: 'On rodem',
    sub: "Els nostres amfitrions omplen les carreteres al voltant de Girona — la capital europea del ciclisme.",
    viewHost: 'Veure amfitrió',
  },
  fr: {
    eyebrow: 'La communauté',
    title: 'Là où nous roulons',
    sub: 'Nos hôtes jalonnent les routes autour de Gérone — la capitale européenne du cyclisme.',
    viewHost: "Voir l'hôte",
  },
}

const t = labels[lang] ?? labels.en

const hostPins = [
  { name: 'Casa Gessamí',    location: "Camós · Pla de l'Estany", lat: 42.0769, lng: 2.8364, slug: 'casa-gessami' },
  { name: 'Casa Romaní',     location: "Camós · Pla de l'Estany", lat: 42.0782, lng: 2.8392, slug: 'casa-romani' },
  { name: 'Alain Fernandez', location: 'Girona',                   lat: 41.9828, lng: 2.8245, slug: 'alain-fernandez' },
  { name: 'Espai 8',         location: 'Banyoles',                 lat: 42.1168, lng: 2.7710, slug: 'espai-8' },
]

const langPrefix = lang === 'en' ? '' : `/${lang}`
---

<section class="py-20" style="background:#1e1812">
  <div class="max-w-5xl mx-auto px-[5vw]">

    <!-- Header -->
    <div class="text-center mb-10 reveal">
      <p class="text-[11px] font-bold tracking-[3px] uppercase mb-2.5" style="color:#A7B75D">{t.eyebrow}</p>
      <h2 class="font-display font-black uppercase leading-[0.95] mb-4" style="color:#F8EEDA;font-size:clamp(32px,6vw,58px)">{t.title}</h2>
      <p class="text-base max-w-md mx-auto" style="color:#ffffff70">{t.sub}</p>
    </div>

    <!-- Map -->
    <div class="reveal rounded-2xl overflow-hidden" style="height:420px;border:1px solid #ffffff10">
      <div id="vt-map" style="height:100%;width:100%;background:#2C2419"></div>
    </div>

  </div>
</section>

<style is:global>
  .vt-popup .leaflet-popup-content-wrapper {
    background: #2C2419;
    color: #F8EEDA;
    border-radius: 10px;
    border: 1px solid #ffffff15;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    padding: 0;
  }
  .vt-popup .leaflet-popup-tip {
    background: #2C2419;
  }
  .vt-popup .leaflet-popup-content {
    margin: 14px 16px;
  }
  .leaflet-control-attribution {
    font-size: 9px !important;
    opacity: 0.4;
  }
</style>

<script define:vars={{ hostPins, langPrefix, viewHostLabel: t.viewHost }}>
  function initVTMap() {
    if (!window.L || !document.getElementById('vt-map')) return

    const map = window.L.map('vt-map', {
      center: [42.04, 2.81],
      zoom: 11,
      scrollWheelZoom: false,
      zoomControl: true,
    })

    window.L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map)

    const icon = window.L.divIcon({
      html: `<div style="
        width:16px;height:16px;
        background:#A7B75D;
        border-radius:50%;
        border:2.5px solid #F8EEDA;
        box-shadow:0 0 0 5px rgba(167,183,93,0.25),0 2px 8px rgba(0,0,0,0.4);
        cursor:pointer;
      "></div>`,
      className: '',
      iconSize: [16, 16],
      iconAnchor: [8, 8],
    })

    hostPins.forEach(function (pin) {
      const popup = window.L.popup({ className: 'vt-popup', maxWidth: 200 }).setContent(
        `<div>
          <p style="font-weight:700;font-size:13px;margin:0 0 3px;font-family:sans-serif">${pin.name}</p>
          <p style="font-size:11px;color:#ffffff60;margin:0 0 8px;font-family:sans-serif">${pin.location}</p>
          <a href="${langPrefix}/hosts/${pin.slug}" style="font-size:11px;color:#A7B75D;font-weight:700;text-decoration:none;font-family:sans-serif">${viewHostLabel} →</a>
        </div>`
      )
      window.L.marker([pin.lat, pin.lng], { icon }).addTo(map).bindPopup(popup)
    })
  }

  // Carrega Leaflet dinàmicament només si no s'ha carregat ja
  if (!document.getElementById('leaflet-css')) {
    const css = document.createElement('link')
    css.id = 'leaflet-css'
    css.rel = 'stylesheet'
    css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'
    document.head.appendChild(css)
  }

  if (!window.L) {
    const js = document.createElement('script')
    js.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'
    js.onload = initVTMap
    document.head.appendChild(js)
  } else {
    initVTMap()
  }
</script>
