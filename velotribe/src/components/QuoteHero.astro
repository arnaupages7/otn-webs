---
import { pathFor, type Lang } from '../i18n/utils'

interface Props { lang: Lang }
const { lang } = Astro.props

const t = {
  en: {
    eyebrow: 'Custom cycling weekend',
    headline1: 'Ride Girona.',
    headline2: 'We handle the rest.',
    sub: 'Accommodation, guided rides and airport transfer — tailored to your group and your level.',
    cta: 'Get a free quote',
    pill1: 'Accommodation',
    pill2: 'Guided rides',
    pill3: 'Airport transfer',
    pill4: 'Custom routes',
    scroll: 'Discover VeloTribe',
  },
  es: {
    eyebrow: 'Fin de semana ciclista a medida',
    headline1: 'Pedalea Girona.',
    headline2: 'Del resto nos encargamos.',
    sub: 'Alojamiento, salidas guiadas y transfer al aeropuerto — adaptado a tu grupo y tu nivel.',
    cta: 'Pedir presupuesto gratis',
    pill1: 'Alojamiento',
    pill2: 'Salidas guiadas',
    pill3: 'Transfer aeropuerto',
    pill4: 'Rutas a medida',
    scroll: 'Descubrir VeloTribe',
  },
  ca: {
    eyebrow: 'Cap de setmana ciclista a mida',
    headline1: 'Pedala Girona.',
    headline2: "De la resta ens encarreguem.",
    sub: "Allotjament, sortides guiades i transfer a l'aeroport — adaptat al teu grup i al teu nivell.",
    cta: 'Demana pressupost gratis',
    pill1: 'Allotjament',
    pill2: 'Sortides guiades',
    pill3: 'Transfer aeroport',
    pill4: 'Rutes a mida',
    scroll: 'Descobrir VeloTribe',
  },
  fr: {
    eyebrow: 'Week-end cycliste sur mesure',
    headline1: 'Roulez à Gérone.',
    headline2: "On s'occupe du reste.",
    sub: "Hébergement, sorties guidées et transfert aéroport — adaptés à votre groupe et votre niveau.",
    cta: 'Demander un devis gratuit',
    pill1: 'Hébergement',
    pill2: 'Sorties guidées',
    pill3: 'Transfert aéroport',
    pill4: 'Routes sur mesure',
    scroll: 'Découvrir VeloTribe',
  },
}

const c = t[lang] ?? t.en
const quotePath = pathFor(lang, '/quote')
---

<section id="quote-hero" class="min-h-screen flex flex-col justify-center relative overflow-hidden pt-[60px]" style="background:#2C2419;color:#F8EEDA">

  <!-- Background photo -->
  <img
    src="/hero-1.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover pointer-events-none"
    style="opacity:0.18;object-position:center 35%"
    loading="eager"
  />

  <!-- Gradient overlay -->
  <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(135deg, #2C2419ee 0%, #2C241999 50%, #41372B88 100%)"></div>

  <!-- Wave pattern -->
  <div class="absolute inset-0 pointer-events-none" style="opacity:0.06">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <defs>
        <pattern id="qh-waves" x="0" y="0" width="160" height="22" patternUnits="userSpaceOnUse">
          <path d="M0,11 Q40,2 80,11 T160,11" stroke="#A7B75D" stroke-width="1" fill="none" stroke-linecap="round"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#qh-waves)"/>
    </svg>
  </div>

  <!-- Radial glow left -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 55% 70% at 5% 50%, #A7B75D0d 0%, transparent 65%)"></div>

  <!-- Content -->
  <div class="relative z-10 px-[5vw] py-20 max-w-6xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: text + CTA -->
      <div>
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-8" style="background:#A7B75D18;border:1px solid #A7B75D44">
          <svg class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#A7B75D" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span class="text-[10px] font-bold uppercase tracking-[3px]" style="color:#A7B75D">{c.eyebrow}</span>
        </div>

        <!-- Headline -->
        <h1 class="font-display font-black uppercase leading-[0.88] mb-6" style="font-size:clamp(52px,9vw,96px)">
          <span style="color:#F8EEDA">{c.headline1}</span><br>
          <em class="not-italic" style="color:#A7B75D">{c.headline2}</em>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl font-light leading-relaxed mb-10 max-w-lg" style="color:#c8b89a">{c.sub}</p>

        <!-- CTA -->
        <a href={quotePath}
           class="inline-flex items-center gap-3 px-8 py-4 rounded-xl font-black text-base uppercase tracking-[2px] transition hover:scale-[1.03] hover:shadow-xl active:scale-100"
           style="background:#A7B75D;color:#2C2419;box-shadow:0 8px 32px #A7B75D33">
          {c.cta}
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="5 10 15 10"/><polyline points="10 5 15 10 10 15"/></svg>
        </a>

        <!-- Pills row -->
        <div class="flex flex-wrap gap-2 mt-8">
          {[c.pill1, c.pill2, c.pill3, c.pill4].map(label => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold" style="background:#ffffff08;color:#ffffff60;border:1px solid #ffffff12">
              <span class="w-1 h-1 rounded-full shrink-0" style="background:#A7B75D"></span>
              {label}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: 3 visual feature cards -->
      <div class="hidden lg:grid grid-cols-1 gap-4">

        {[
          {
            n: '01',
            icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            en: { title: 'You choose the dates', desc: 'Fixed or flexible — we plan around your calendar.' },
            es: { title: 'Tú eliges las fechas', desc: 'Fijas o flexibles — nos adaptamos a tu agenda.' },
            ca: { title: 'Tu tries les dates', desc: 'Fixes o flexibles — ens adaptem al teu calendari.' },
            fr: { title: 'Vous choisissez les dates', desc: 'Fixes ou flexibles — on s\'adapte à votre agenda.' },
          },
          {
            n: '02',
            icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
            en: { title: 'Routes built for you', desc: 'Road, gravel or MTB. Easy or sportive. We know every climb.' },
            es: { title: 'Rutas hechas para ti', desc: 'Carretera, gravel o MTB. Social o deportivo. Conocemos cada puerto.' },
            ca: { title: 'Rutes fetes per a tu', desc: 'Carretera, gravel o MTB. Social o esportiu. Coneixem cada coll.' },
            fr: { title: 'Des routes faites pour vous', desc: 'Route, gravel ou VTT. Social ou sportif. On connaît chaque col.' },
          },
          {
            n: '03',
            icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
            en: { title: 'Everything taken care of', desc: 'Accommodation, transfers, guides. You just ride.' },
            es: { title: 'Todo organizado', desc: 'Alojamiento, transfers, guías. Tú solo pedaleas.' },
            ca: { title: 'Tot organitzat', desc: 'Allotjament, transfers, guies. Tu només pedales.' },
            fr: { title: 'Tout est organisé', desc: 'Hébergement, transfers, guides. Vous n\'avez qu\'à rouler.' },
          },
        ].map((card) => {
          const content = card[lang as 'en'|'es'|'ca'|'fr'] ?? card.en
          return (
            <div class="flex items-start gap-4 p-6 rounded-2xl" style="background:#ffffff06;border:1px solid #ffffff10;backdrop-filter:blur(4px)">
              <div class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background:#A7B75D18">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#A7B75D" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={card.icon}/>
                </svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-[2px] mb-1" style="color:#A7B75D55">{card.n}</p>
                <p class="font-bold text-sm mb-1" style="color:#F8EEDA">{content.title}</p>
                <p class="text-xs leading-relaxed" style="color:#ffffff45">{content.desc}</p>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <a href="#hero" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 group cursor-pointer z-10">
    <p class="text-[10px] uppercase tracking-[2px] font-semibold transition group-hover:text-[#A7B75D]" style="color:#ffffff25">{c.scroll}</p>
    <span class="block w-3 h-3 border-r-2 border-b-2 animate-bounce" style="border-color:#ffffff25;transform:rotate(45deg)"></span>
  </a>

</section>
