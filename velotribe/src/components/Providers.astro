---
import { type Lang } from '../i18n/utils'

interface Props { lang: Lang }
const { lang } = Astro.props

const labels = {
  en: {
    eyebrow: 'Hosts joining the tribe',
    note: 'Closing the first partnerships in Girona. Be one of them.',
    items: ['Rural hotels', 'Cycling-friendly B&Bs', 'Certified local guides', 'Tour operators', 'Cycling cafés', 'Bike shops'],
  },
  es: {
    eyebrow: 'Anfitriones que se sumarán a la tribu',
    note: 'Cerrando los primeros acuerdos en Girona. Sé uno de ellos.',
    items: ['Hoteles rurales', 'B&Bs cycling-friendly', 'Guías locales certificados', 'Tour operators', 'Cafés ciclistas', 'Tiendas de bici'],
  },
  ca: {
    eyebrow: 'Amfitrions que s\'uniran a la tribu',
    note: 'Tancant els primers acords a Girona. Sigues un d\'ells.',
    items: ['Hotels rurals', 'B&Bs cycling-friendly', 'Guies locals certificats', 'Tour operators', 'Cafès ciclistes', 'Botigues de bici'],
  },
}

const data = labels[lang]
---

<section id="providers" class="px-[5vw] py-14 text-center bg-white">
  <p class="text-[11px] font-bold tracking-[3px] uppercase mb-5" style="color:#9a8c7a">{data.eyebrow}</p>
  <div class="flex flex-wrap gap-2.5 justify-center max-w-3xl mx-auto">
    {data.items.map((c) => (
      <span class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold border" style="background:#F8EEDA;border-color:#e8e0d4;color:#41372B">
        <span class="w-1.5 h-1.5 rounded-full" style="background:#A7B75D"></span>
        {c}
      </span>
    ))}
  </div>
  <p class="text-xs italic mt-5" style="color:#9a8c7a">{data.note}</p>
</section>
