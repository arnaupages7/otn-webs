---
import { type Lang } from '../i18n/utils'
import { providers, tagLabels, badgeLabels, type Provider } from '../data/providers'

interface Props { lang: Lang }
const { lang } = Astro.props

const labels = {
  en: {
    eyebrow: 'Founding hosts',
    title: 'The first of the tribe',
    sub: 'Handpicked hosts already committed to the VeloTribe community.',
    soon_name: 'Joining soon',
    soon_desc: 'More founding hosts are confirming. Stay tuned.',
    visit: 'Visit website',
    type: {
      accommodation: 'Accommodation',
      guide: 'Guide',
      tour: 'Tour operator',
      cafe: 'Café',
      shop: 'Bike shop',
    },
  },
  es: {
    eyebrow: 'Anfitriones fundadores',
    title: 'Los primeros de la tribu',
    sub: 'Anfitriones seleccionados a mano que ya forman parte de la comunidad VeloTribe.',
    soon_name: 'Próximamente',
    soon_desc: 'Más anfitriones fundadores están confirmando. Muy pronto.',
    visit: 'Ver web',
    type: {
      accommodation: 'Alojamiento',
      guide: 'Guía',
      tour: 'Tour operator',
      cafe: 'Café',
      shop: 'Tienda de bici',
    },
  },
  ca: {
    eyebrow: 'Amfitrions fundadors',
    title: 'Els primers de la tribu',
    sub: "Amfitrions seleccionats a mà que ja formen part de la comunitat VeloTribe.",
    soon_name: 'Properament',
    soon_desc: 'Més amfitrions fundadors estan confirmant. Molt aviat.',
    visit: 'Veure web',
    type: {
      accommodation: 'Allotjament',
      guide: 'Guia',
      tour: 'Tour operator',
      cafe: 'Cafè',
      shop: 'Botiga de bici',
    },
  },
}

const t = labels[lang]
const activeProviders = providers.filter(p => p.active)
const soonSlots = providers.filter(p => !p.active)
---

<section id="providers" class="px-[5vw] py-20" style="background:#F8EEDA">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[11px] font-bold tracking-[3px] uppercase mb-2.5" style="color:#A7B75D">{t.eyebrow}</p>
      <h2 class="font-display font-black uppercase leading-[0.95]" style="color:#41372B;font-size:clamp(32px,6vw,58px)">{t.title}</h2>
      <p class="text-base mt-4 max-w-md mx-auto" style="color:#9a8c7a">{t.sub}</p>
    </div>

    <!-- Graella de targetes -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal">

      <!-- Targetes actives -->
      {activeProviders.map((p: Provider) => (
        <div class="lift rounded-2xl overflow-hidden flex flex-col" style="background:#41372B">

          <!-- Imatge -->
          {p.image ? (
            <div class="relative h-48 overflow-hidden">
              <img
                src={p.image}
                alt={p.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              {p.badge && (
                <span class="absolute top-3 left-3 px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-[1.5px]"
                  style="background:#A7B75D;color:#2C2419">
                  {badgeLabels[p.badge][lang]}
                </span>
              )}
            </div>
          ) : (
            <!-- Placeholder imatge quan encara no n'hi ha -->
            <div class="relative h-48 flex items-center justify-center" style="background:#2C2419">
              <svg class="w-12 h-12 opacity-20" viewBox="0 0 24 24" fill="none" stroke="#F8EEDA" stroke-width="1" stroke-linecap="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              {p.badge && (
                <span class="absolute top-3 left-3 px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-[1.5px]"
                  style="background:#A7B75D;color:#2C2419">
                  {badgeLabels[p.badge][lang]}
                </span>
              )}
            </div>
          )}

          <!-- Contingut -->
          <div class="p-6 flex flex-col flex-1">
            <!-- Tipus -->
            <span class="text-[10px] font-bold uppercase tracking-[2px] mb-2" style="color:#A7B75D">
              {t.type[p.type]}
            </span>

            <!-- Nom + ubicació -->
            <h3 class="font-display font-black text-xl uppercase leading-tight mb-1" style="color:#F8EEDA">
              {p.name}
            </h3>
            <p class="text-xs mb-4 flex items-center gap-1.5" style="color:#ffffff60">
              <svg class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {p.location}
            </p>

            <!-- Descripció -->
            {p.description[lang] && (
              <p class="text-sm leading-relaxed mb-5 flex-1" style="color:#ffffff80">
                {p.description[lang]}
              </p>
            )}

            <!-- Tags de serveis -->
            {p.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mb-5">
                {p.tags.map(tag => (
                  <span class="text-[10px] px-2 py-0.5 rounded-full border font-medium" style="border-color:#A7B75D44;color:#A7B75D;background:#A7B75D11">
                    {tagLabels[tag][lang]}
                  </span>
                ))}
              </div>
            )}

            <!-- CTA -->
            {p.website && (
              <a
                href={p.website}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-bold transition hover:gap-3"
                style="color:#A7B75D"
              >
                {t.visit}
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </div>
      ))}

      <!-- Targetes "joining soon" -->
      {soonSlots.map(() => (
        <div class="rounded-2xl overflow-hidden flex flex-col opacity-40" style="background:#41372B;border:1px dashed #ffffff20">
          <div class="h-48 flex items-center justify-center" style="background:#2C2419">
            <svg class="w-8 h-8 opacity-30" viewBox="0 0 24 24" fill="none" stroke="#F8EEDA" stroke-width="1.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
          </div>
          <div class="p-6">
            <p class="font-display font-black text-xl uppercase mb-2" style="color:#F8EEDA">{t.soon_name}</p>
            <p class="text-sm" style="color:#ffffff50">{t.soon_desc}</p>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>
