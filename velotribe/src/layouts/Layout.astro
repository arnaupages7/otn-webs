---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  lang?: 'en' | 'es' | 'ca' | 'fr'
  ogImage?: string
}

const { title, description, lang = 'en', ogImage = '/og-image.jpg' } = Astro.props
// Astro.site ve d'astro.config.mjs (env PUBLIC_SITE_URL amb fallback a pages.dev)
const siteOrigin = Astro.site ?? new URL('https://velotribe.pages.dev')
const url = new URL(Astro.url.pathname, siteOrigin).toString()
const ogImageAbs = new URL(ogImage, siteOrigin).toString()
const hrefEn = new URL('/', siteOrigin).toString()
const hrefEs = new URL('/es/', siteOrigin).toString()
const hrefCa = new URL('/ca/', siteOrigin).toString()
const hrefFr = new URL('/fr/', siteOrigin).toString()
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VeloTribe" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={hrefEn} />
    <link rel="alternate" hreflang="es" href={hrefEs} />
    <link rel="alternate" hreflang="ca" href={hrefCa} />
    <link rel="alternate" hreflang="fr" href={hrefFr} />
    <link rel="alternate" hreflang="x-default" href={hrefEn} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Didact+Gothic&family=Oswald:wght@600;700;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'VeloTribe',
      url: siteOrigin.toString().replace(/\/$/, ''),
      logo: new URL('/logo/velotribe.svg', siteOrigin).toString(),
      description: 'The cycling community platform connecting cyclists with local hosts in Girona and beyond.',
      sameAs: []
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'VeloTribe',
      url: siteOrigin.toString().replace(/\/$/, ''),
      inLanguage: ['en', 'es', 'ca']
    })} />

    <!-- Cloudflare Web Analytics (privacy-first, no cookies) -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "9d88c2c0ec414e999bfc5ddb446532a1"}'></script>
  </head>
  <body class="min-h-screen bg-cream text-brown font-body antialiased">
    <slot />

    <!-- Cookie consent banner -->
    <div id="cookie-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:100;background:#2C2419;color:#F8EEDA;padding:1rem 1.5rem;box-shadow:0 -2px 16px rgba(0,0,0,0.3);">
      <div style="max-width:900px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:1rem;justify-content:space-between;">
        <p id="cookie-text" style="margin:0;font-size:0.85rem;line-height:1.5;flex:1;min-width:200px;"></p>
        <div style="display:flex;gap:0.625rem;flex-shrink:0;">
          <button id="cookie-reject"
            style="padding:0.5rem 1.1rem;border-radius:4px;border:1px solid #706050;background:transparent;color:#F8EEDA;font-size:0.8rem;cursor:pointer;transition:background 0.2s;"
            onmouseover="this.style.background='rgba(255,255,255,0.08)'"
            onmouseout="this.style.background='transparent'">
          </button>
          <button id="cookie-accept"
            style="padding:0.5rem 1.1rem;border-radius:4px;border:none;background:#A7B75D;color:#2C2419;font-size:0.8rem;font-weight:700;cursor:pointer;transition:background 0.2s;"
            onmouseover="this.style.background='#c5d46e'"
            onmouseout="this.style.background='#A7B75D'">
          </button>
        </div>
      </div>
    </div>

    <script define:vars={{ lang }}>
      (function () {
        var msgs = {
          en: {
            text: 'We use cookies to analyse visits and improve your experience. <a href="/cookies" style="color:#A7B75D;text-decoration:underline;">Cookie policy</a>.',
            accept: 'Accept',
            reject: 'Reject',
          },
          es: {
            text: 'Usamos cookies para analizar visitas y mejorar tu experiencia. <a href="/es/cookies" style="color:#A7B75D;text-decoration:underline;">Política de cookies</a>.',
            accept: 'Aceptar',
            reject: 'Rechazar',
          },
          ca: {
            text: 'Usem cookies per analitzar visites i millorar la teva experiència. <a href="/ca/cookies" style="color:#A7B75D;text-decoration:underline;">Política de galetes</a>.',
            accept: 'Acceptar',
            reject: 'Rebutjar',
          },
          fr: {
            text: 'Nous utilisons des cookies pour analyser les visites et améliorer votre expérience. <a href="/fr/cookies" style="color:#A7B75D;text-decoration:underline;">Politique de cookies</a>.',
            accept: 'Accepter',
            reject: 'Refuser',
          },
        }

        var l = msgs[lang] || msgs.en
        var banner = document.getElementById('cookie-banner')
        var textEl = document.getElementById('cookie-text')
        var acceptBtn = document.getElementById('cookie-accept')
        var rejectBtn = document.getElementById('cookie-reject')

        textEl.innerHTML = l.text
        acceptBtn.textContent = l.accept
        rejectBtn.textContent = l.reject

        var consent = localStorage.getItem('vt-cookie-consent')

        function loadAnalytics() {
          // Google Analytics 4
          var s = document.createElement('script')
          s.async = true
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX'
          document.head.appendChild(s)
          window.dataLayer = window.dataLayer || []
          function gtag() { window.dataLayer.push(arguments) }
          window.gtag = gtag
          gtag('js', new Date())
          gtag('config', 'G-XXXXXXXXXX')

          // Meta Pixel
          ;(function (f, b, e, v, n, t, s) {
            if (f.fbq) return
            n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments) }
            if (!f._fbq) f._fbq = n
            n.push = n; n.loaded = true; n.version = '2.0'; n.queue = []
            t = b.createElement(e); t.async = true; t.src = v
            s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s)
          })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js')
          window.fbq('init', 'XXXXXXXXXXXXXXXXX')
          window.fbq('track', 'PageView')
        }

        if (consent === 'accepted') {
          loadAnalytics()
        } else if (consent === null) {
          banner.style.display = 'block'
        }

        acceptBtn.addEventListener('click', function () {
          localStorage.setItem('vt-cookie-consent', 'accepted')
          banner.style.display = 'none'
          loadAnalytics()
        })

        rejectBtn.addEventListener('click', function () {
          localStorage.setItem('vt-cookie-consent', 'rejected')
          banner.style.display = 'none'
        })
      })()
    </script>

    <!-- Social floating buttons -->
    <div style="position:fixed;bottom:1.25rem;right:1.25rem;z-index:50;display:flex;flex-direction:column;gap:0.625rem;align-items:center;">
      <a href="https://www.instagram.com/velotribe.cc/" target="_blank" rel="noopener noreferrer" aria-label="Instagram VeloTribe"
        style="display:flex;align-items:center;justify-content:center;width:2.75rem;height:2.75rem;border-radius:50%;background:#2C2419;box-shadow:0 2px 8px rgba(0,0,0,0.35);transition:transform 0.2s,background 0.2s;"
        onmouseover="this.style.background='#A7B75D';this.style.transform='scale(1.1)'"
        onmouseout="this.style.background='#2C2419';this.style.transform='scale(1)'">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#F8EEDA">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a href="https://www.strava.com/clubs/velotribe" target="_blank" rel="noopener noreferrer" aria-label="Strava VeloTribe"
        style="display:flex;align-items:center;justify-content:center;width:2.75rem;height:2.75rem;border-radius:50%;background:#2C2419;box-shadow:0 2px 8px rgba(0,0,0,0.35);transition:transform 0.2s,background 0.2s;"
        onmouseover="this.style.background='#FC4C02';this.style.transform='scale(1.1)'"
        onmouseout="this.style.background='#2C2419';this.style.transform='scale(1)'">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#F8EEDA">
          <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/>
        </svg>
      </a>
    </div>

    <!-- Reveal on scroll (progressive enhancement) -->
    <script>
      // Marquem JS disponible perquè el CSS .reveal s'activi (sense JS, mostrem tot)
      document.documentElement.classList.add('js-ready')
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible')
            observer.unobserve(entry.target)
          }
        })
      }, { threshold: 0.1, rootMargin: '0px 0px -10% 0px' })
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))
    </script>
  </body>
</html>
