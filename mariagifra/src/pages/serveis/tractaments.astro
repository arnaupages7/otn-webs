---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'

const serveis = [
  {
    nom: 'Keratina',
    subtitol: 'L\'allisat definitiu',
    tecnica: 'Tractament de suavitzat i reconstrucció capil·lar a base de queratina hidrolitzada, la proteïna natural del cabell. S\'aplica amb calor (planxa a alta temperatura) per segellar l\'estructura del cabell, eliminant el frissat i l\'encrespat fins al 90%. Resultat: cabell llis, sedós, brillant i fàcil de pentinar durant 3 a 5 mesos. Adequat per a tots els tipus de cabell.',
    foto: 'https://images.unsplash.com/photo-1604654894610-df63bc536371?w=800&q=80',
    alt: 'Tractament de keratina professional',
    durada: '3 – 5 mesos',
  },
  {
    nom: 'Hidratació profunda',
    subtitol: 'Nutrició intensiva',
    tecnica: 'Màscara de tractament d\'alta concentració aplicada amb calor per obrir les escates del cabell i permetre la penetració dels actius. Usem fórmules riques en àcid hialurònic, proteïnes de seda i olis vegetals que restauren la hidratació perduda per l\'ús de color, calor o el sol. El cabell queda suau, brillant i manejable. Recomanat com a manteniment mensual per a cabells tractats.',
    foto: 'https://images.unsplash.com/photo-1519823551278-64ac92734fb1?w=800&q=80',
    alt: 'Hidratació profunda de cabell',
    durada: 'Efecto immediat + 4 setmanes',
  },
  {
    nom: 'Permanent',
    subtitol: 'Arrissats naturals i duradors',
    tecnica: 'Tècnica química que modifica l\'estructura interna del cabell per crear arrissat permanent. Apliquem una loció reductora que trenca els ponts de disulfur del cabell, el modelem als rods del diàmetre desitjat i neutralitzem per fixar la nova forma. El resultat dura entre 3 i 6 mesos i permet obtenir des de ones suaus fins a arrissats molt definits, depenent del diàmetre dels ròtuls usats.',
    foto: 'https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?w=800&q=80',
    alt: 'Cabell amb permanent, rulls naturals',
    durada: '3 – 6 mesos',
  },
  {
    nom: 'Allisat',
    subtitol: 'Suavitat i control',
    tecnica: 'Tractament químic que relaxa el frissat natural de forma permanent. A diferència de la keratina, l\'allisat modifica l\'estructura del cabell de forma irreversible, eliminant el rínxol fins al nou creixement. Ideal per a cabells molt frisats o arrissats que volen una alternativa permanent al secador diari. El resultat és un cabell absolutament llis i brillant des de l\'arrel fins a la punta.',
    foto: 'https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=800&q=80',
    alt: 'Cabell allisat amb planxa',
    durada: 'Permanent (fins al nou creixement)',
  },
]
---

<Layout
  title="Tractaments — Maria Gifra & Paula Perruquers"
  description="Tractaments capil·lars professionals a Porqueres. Keratina, hidratació profunda, permanent i allisat. Restaura i cuida el teu cabell."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-[50vh] flex items-center justify-center pt-16 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('https://images.unsplash.com/photo-1519823551278-64ac92734fb1?w=1600&q=80'), linear-gradient(135deg, #1a1514 0%, #3a2f2a 100%); filter: brightness(0.28);"
    ></div>
    <div class="relative z-10 text-center px-4 max-w-3xl">
      <a href="/#serveis" class="text-brand-300 text-sm font-medium tracking-widest uppercase mb-4 inline-block hover:text-brand-200 transition-colors">
        ← Tots els serveis
      </a>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-white leading-tight mb-4 mt-2">
        Tractaments
      </h1>
      <p class="text-brand-200/80 text-lg max-w-xl mx-auto">
        Recupera la força, la lluentor i la vida del teu cabell amb tractaments professionals.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-16 bg-warm-50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-brand-500 font-semibold text-sm tracking-widest uppercase mb-4">Cura capil·lar</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-warm-900 mb-6">
        El cabell sa és el cabell bonic
      </h2>
      <p class="text-warm-800/70 text-lg leading-relaxed">
        El color, la calor i el sol desgasten el cabell amb el temps. Els nostres tractaments restauren
        l'estructura capil·lar des de dins, devolent-li l'elasticitat, la brillantor i la facilitat
        de pentinar que mereix.
      </p>
    </div>
  </section>

  <!-- SERVEIS GRID amb durada -->
  <section class="py-8 bg-warm-100">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        {serveis.map((s) => (
          <div class="bg-warm-50 rounded-2xl overflow-hidden shadow-sm border border-brand-100">
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={s.foto}
                alt={s.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-8">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-display text-2xl font-bold text-warm-900">{s.nom}</h3>
                <span class="bg-brand-100 text-brand-700 text-xs font-medium px-3 py-1 rounded-full whitespace-nowrap ml-4 mt-1">
                  {s.durada}
                </span>
              </div>
              <p class="text-brand-500 font-medium text-sm mb-4 italic">{s.subtitol}</p>
              <p class="text-warm-800/70 leading-relaxed">{s.tecnica}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand-800 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="font-display text-3xl font-bold text-white mb-4">El teu cabell mereix atenció</h2>
      <p class="text-brand-200/70 mb-8">Consulta'ns quin tractament és el més adequat per al teu tipus de cabell.</p>
      <a
        href="tel:+34972572601"
        class="inline-flex items-center justify-center bg-white text-brand-800 px-8 py-4 rounded-xl text-lg font-semibold hover:bg-brand-100 transition-colors"
      >
        Demanar cita — 972 572 601
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand-900 text-brand-200/50 py-8">
    <div class="max-w-6xl mx-auto px-4 text-center text-sm">
      <p class="font-display text-brand-300 text-lg mb-2 italic">Maria Gifra & Paula Perruquers</p>
      <p>Carrer de les Pedreres, 19 · 17182 Porqueres · 972 572 601</p>
      <p class="mt-4 text-brand-200/30">&copy; {new Date().getFullYear()} Maria Gifra & Paula Perruquers.</p>
    </div>
  </footer>

  <!-- MOBILE CTA -->
  <div class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
    <a
      href="tel:+34972572601"
      class="bg-brand-700 text-white px-8 py-4 rounded-full text-lg font-bold shadow-2xl hover:bg-brand-800 transition-colors flex items-center gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      Demanar cita
    </a>
  </div>
</Layout>
