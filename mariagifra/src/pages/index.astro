---
import Layout from '../layouts/Layout.astro'

const serveis = [
  {
    categoria: 'Tall i forma',
    href: '/serveis/tall',
    items: [
      { nom: 'Tall de cabell' },
      { nom: 'Tall i assecada' },
      { nom: 'Tall d\'home' },
      { nom: 'Franja i bigoti' },
    ],
  },
  {
    categoria: 'Color',
    href: '/serveis/color',
    items: [
      { nom: 'Tint complet' },
      { nom: 'Mèxes' },
      { nom: 'Balayage', desc: 'Color gradual i natural, resultat lluminós' },
      { nom: 'Babylights', desc: 'Aclariments ultrafins per un efecte molt natural' },
      { nom: 'Retoc de color' },
    ],
  },
  {
    categoria: 'Tractaments',
    href: '/serveis/tractaments',
    items: [
      { nom: 'Keratina' },
      { nom: 'Hidratació profunda' },
      { nom: 'Permanent' },
      { nom: 'Allisat' },
    ],
  },
  {
    categoria: 'Nupcial i ocasions',
    href: '/serveis/nupcial',
    items: [
      { nom: 'Pentinat de núvia' },
      { nom: 'Pentinat de festa' },
      { nom: 'Recollits' },
    ],
  },
]

const horaris = [
  { dia: 'Dilluns',    hores: 'Tancat' },
  { dia: 'Dimarts',   hores: '9:00 – 19:00' },
  { dia: 'Dimecres',  hores: '9:00 – 19:00' },
  { dia: 'Dijous',    hores: '9:00 – 19:00' },
  { dia: 'Divendres', hores: '9:00 – 19:00' },
  { dia: 'Dissabte',  hores: '9:00 – 14:00' },
  { dia: 'Diumenge',  hores: 'Tancat' },
]

const today = new Date().getDay()
const dayMap: Record<number, number> = { 0: 6, 1: 0, 2: 1, 3: 2, 4: 3, 5: 4, 6: 5 }
const todayIndex = dayMap[today] ?? 0
---

<Layout
  title="Maria Gifra & Paula Perruquers — Porqueres"
  description="Perruqueria a Porqueres des de 1967. Especialistes en color, balayage, babylights, tall i tractaments. Demana cita al 972 572 601."
>
  <!-- NAV -->
  <nav class="fixed top-0 w-full z-50 bg-warm-50/90 backdrop-blur-md border-b border-brand-100">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="#" class="font-display text-xl font-bold text-brand-700 italic">Maria Gifra & Paula</a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-warm-800">
        <a href="#serveis" class="hover:text-brand-600 transition-colors">Serveis</a>
        <a href="#nosaltres" class="hover:text-brand-600 transition-colors">Nosaltres</a>
        <a href="#horaris" class="hover:text-brand-600 transition-colors">Horaris</a>
        <a href="#contacte" class="hover:text-brand-600 transition-colors">Contacte</a>
      </div>
      <a
        href="tel:+34972572601"
        class="bg-brand-700 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-brand-800 transition-colors"
      >
        Demanar cita
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center justify-center pt-16 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('https://images.unsplash.com/photo-1560066984-138daaa7b9e6?w=1600&q=80'), linear-gradient(135deg, #1a1514 0%, #4a3a37 100%); filter: brightness(0.28);"
    >
    </div>
    <div class="relative z-10 text-center px-4 max-w-3xl">
      <p class="text-brand-300 font-medium tracking-widest uppercase text-sm mb-4">
        Porqueres · Des de 1967
      </p>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white leading-tight mb-6">
        L'art del tall<br />
        <span class="text-brand-300 italic font-normal">i el color</span>
      </h1>
      <p class="text-brand-200/80 text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
        Perruqueria familiar a Porqueres. Especialistes en color, balayage i
        tractaments capil·lars per a homes i dones.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+34972572601"
          class="bg-brand-600 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-brand-500 transition-colors"
        >
          Demanar cita — 972 572 601
        </a>
        <a
          href="#serveis"
          class="border-2 border-white/30 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-white/10 transition-colors"
        >
          Veure serveis
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURES BAR -->
  <section class="bg-brand-800 text-brand-100">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-wrap justify-center gap-x-12 gap-y-3 text-sm tracking-wide uppercase">
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-400"></span> Color i balayage</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-400"></span> Babylights</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-400"></span> Homes i dones</span>
      <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-400"></span> Tractaments capil·lars</span>
    </div>
  </section>

  <!-- COLOR HIGHLIGHT -->
  <section class="py-20 bg-warm-50">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-brand-500 font-semibold text-sm tracking-widest uppercase mb-3">La nostra especialitat</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-warm-900 mb-6">
          Color<br />que transforma
        </h2>
        <p class="text-warm-800/70 text-lg leading-relaxed mb-4">
          Especialistes en tècniques de color modernes: balayage, babylights i mèxes.
          Cada servei és personalitzat per adaptar-se al teu to de pell i estil de vida.
        </p>
        <p class="text-warm-800/70 text-lg leading-relaxed mb-6">
          Usem productes d'alta qualitat per garantir un color viu, durador
          i respectuós amb el cabell.
        </p>
        <p class="text-brand-600 font-medium">
          Consulteu disponibilitat per telèfon o Instagram
        </p>
      </div>
      <div class="relative">
        <img
          src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=80"
          alt="Tècnica de color balayage a Maria Gifra & Paula Perruquers"
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-xl"
          loading="lazy"
        />
        <div class="absolute -bottom-4 -left-4 bg-brand-700 text-white px-5 py-3 rounded-xl font-display text-lg italic shadow-lg">
          Des de 1967
        </div>
      </div>
    </div>
  </section>

  <!-- SERVEIS -->
  <section id="serveis" class="py-20 bg-brand-800">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-4 mb-4">
          <span class="h-px w-12 bg-brand-400/40"></span>
          <p class="text-brand-400 font-semibold text-sm tracking-widest uppercase">El que oferim</p>
          <span class="h-px w-12 bg-brand-400/40"></span>
        </div>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white">Els nostres serveis</h2>
        <p class="text-brand-200/50 mt-4 max-w-lg mx-auto">
          Tractaments professionals adaptats a cada cabell i cada persona.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {serveis.map((cat) => (
          <a href={cat.href} class="group bg-brand-900/50 rounded-2xl p-8 border border-brand-700/30 hover:border-brand-500/50 hover:bg-brand-900/70 transition-all block">
            <div class="flex items-center gap-3 mb-6">
              <span class="h-px grow bg-brand-600/30"></span>
              <h3 class="font-display text-xl font-bold text-brand-300 tracking-wide uppercase">{cat.categoria}</h3>
              <span class="h-px grow bg-brand-600/30"></span>
            </div>
            <div class="space-y-4 mb-6">
              {cat.items.map((item) => (
                <div>
                  <span class="font-medium text-brand-100">{item.nom}</span>
                  {'desc' in item && item.desc && (
                    <span class="block text-sm text-brand-200/40 mt-0.5 italic">{item.desc}</span>
                  )}
                </div>
              ))}
            </div>
            <span class="text-brand-400 text-sm font-medium group-hover:text-brand-300 transition-colors">
              Veure tècniques →
            </span>
          </a>
        ))}
      </div>

      <p class="text-center text-brand-200/30 text-sm mt-12">
        Consulteu preus i disponibilitat directament a la perruqueria.
      </p>
    </div>
  </section>

  <!-- NOSALTRES -->
  <section id="nosaltres" class="py-20 bg-warm-50">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <img
          src="https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?w=800&q=80"
          alt="Interior de la perruqueria Maria Gifra & Paula a Porqueres"
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-xl"
          loading="lazy"
        />
      </div>
      <div>
        <p class="text-brand-500 font-semibold text-sm tracking-widest uppercase mb-3">Qui som</p>
        <h2 class="font-display text-4xl font-bold text-warm-900 mb-6">
          Una perruqueria de tota la vida
        </h2>
        <p class="text-warm-800/70 text-lg leading-relaxed mb-4">
          Des de 1967, Maria Gifra & Paula Perruquers és una referència al Pla de l'Estany.
          Més de 55 anys cuidant el cabell dels veïns de Porqueres i rodalies.
        </p>
        <p class="text-warm-800/70 text-lg leading-relaxed mb-6">
          Combinem l'experiència de tota una vida amb les tendències i tècniques més actuals,
          per oferir un servei proper, professional i de qualitat.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="bg-brand-100 text-brand-700 px-4 py-2 rounded-lg text-sm font-medium">Des de 1967</span>
          <span class="bg-brand-100 text-brand-700 px-4 py-2 rounded-lg text-sm font-medium">Homes i dones</span>
          <span class="bg-brand-100 text-brand-700 px-4 py-2 rounded-lg text-sm font-medium">Tracte personal</span>
          <span class="bg-brand-100 text-brand-700 px-4 py-2 rounded-lg text-sm font-medium">Productes qualitat</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HORARIS -->
  <section id="horaris" class="py-20 bg-brand-800 text-brand-100">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-400 font-semibold text-sm tracking-widest uppercase mb-3">Quan obrim</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white">Horaris</h2>
      </div>
      <div class="max-w-md mx-auto">
        {horaris.map((h, i) => (
          <div
            class:list={[
              'flex justify-between py-4 border-b border-brand-700/50 text-lg',
              i === todayIndex && 'text-brand-300 font-bold',
              h.hores === 'Tancat' && 'text-brand-100/40',
            ]}
          >
            <span>{h.dia}</span>
            <span>{h.hores}</span>
          </div>
        ))}
      </div>
      <p class="text-center text-brand-400/60 text-sm mt-8">
        Horaris orientatius · Truqueu per confirmar disponibilitat
      </p>
    </div>
  </section>

  <!-- CONTACTE -->
  <section id="contacte" class="py-20 bg-warm-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-brand-500 font-semibold text-sm tracking-widest uppercase mb-3">On som</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-warm-900">Vine a veure'ns</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-2xl overflow-hidden shadow-lg aspect-[4/3]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2950.2!2d2.7398!3d42.1018!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12bae4e4e4e4e4e4%3A0x0!2zNDLCsDA2JzA2LjUiTiAywrA0NCcyMy4zIkU!5e0!3m2!1sca!2ses!4v1!5m2!1sca!2ses"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicació Maria Gifra & Paula Perruquers, Porqueres"
          ></iframe>
        </div>

        <div class="flex flex-col justify-center space-y-8">
          <div>
            <h3 class="font-display text-xl font-bold text-warm-900 mb-2">Adreça</h3>
            <p class="text-warm-800/70 text-lg">
              Carrer de les Pedreres, 19<br />
              17182 Porqueres, Girona
            </p>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-warm-900 mb-2">Telèfon</h3>
            <a href="tel:+34972572601" class="text-brand-600 text-xl font-semibold hover:text-brand-700 transition-colors">
              972 572 601
            </a>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-warm-900 mb-2">Segueix-nos</h3>
            <a
              href="https://www.instagram.com/mariagifra_perruquers/"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-brand-100 text-brand-700 px-5 py-3 rounded-xl font-medium hover:bg-brand-200 transition-colors inline-block"
            >
              @mariagifra_perruquers
            </a>
          </div>
          <a
            href="tel:+34972572601"
            class="inline-flex items-center justify-center bg-brand-700 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-brand-800 transition-colors w-fit"
          >
            Demanar cita — 972 572 601
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand-900 text-brand-200/50 py-8">
    <div class="max-w-6xl mx-auto px-4 text-center text-sm">
      <p class="font-display text-brand-300 text-lg mb-2 italic">Maria Gifra & Paula Perruquers</p>
      <p>Carrer de les Pedreres, 19 · 17182 Porqueres · 972 572 601</p>
      <p class="mt-4 text-brand-200/30">
        &copy; {new Date().getFullYear()} Maria Gifra & Paula Perruquers. Tots els drets reservats.
      </p>
    </div>
  </footer>

  <!-- MOBILE FLOATING CTA -->
  <div class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
    <a
      href="tel:+34972572601"
      class="bg-brand-700 text-white px-8 py-4 rounded-full text-lg font-bold shadow-2xl hover:bg-brand-800 transition-colors flex items-center gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      Demanar cita
    </a>
  </div>
</Layout>
